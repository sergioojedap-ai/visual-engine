<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 19 - Suministros en Incidentes</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #eef4fb;
    }

    .slide {
      width: 1600px;
      height: 900px;
      background: linear-gradient(180deg, #ffffff 0%, #f3f8ff 100%);
      color: #08245c;
      overflow: hidden;
      position: relative;
      padding: 18px 24px 16px 24px;
    }

    .corner {
      position: absolute;
      right: 0;
      top: 0;
      width: 330px;
      height: 86px;
      background: linear-gradient(135deg, #082b85, #0c4bc0);
      border-bottom-left-radius: 95px;
      z-index: 0;
    }

    .header {
      position: relative;
      z-index: 2;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .title-wrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .title-bar {
      width: 12px;
      height: 56px;
      border-radius: 5px;
      background: #1565df;
    }

    .title {
      font-size: 42px;
      font-weight: 900;
      color: #071f5c;
      letter-spacing: -0.5px;
      text-transform: uppercase;
    }

    .logo {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 14px;
      color: white;
      font-size: 38px;
      font-weight: 900;
      padding-right: 28px;
    }

    .logo-symbol {
      width: 44px;
      height: 26px;
      border-radius: 50%;
      border: 4px dashed rgba(255,255,255,0.85);
      transform: rotate(-18deg);
    }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 14px;
      margin-bottom: 16px;
    }

    .kpi-card {
      height: 122px;
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 16px;
      box-shadow: 0 6px 14px rgba(11, 45, 92, 0.16);
      display: grid;
      grid-template-columns: 76px 1fr;
      gap: 14px;
      align-items: center;
      padding: 14px 16px;
    }

    .kpi-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 34px;
      font-weight: 900;
      box-shadow: 0 8px 16px rgba(0,0,0,0.16);
    }

    .bg-blue {
      background: linear-gradient(135deg, #1264df, #06339b);
    }

    .bg-teal {
      background: linear-gradient(135deg, #18c4c7, #087a87);
    }

    .bg-orange {
      background: linear-gradient(135deg, #ffb51d, #ff5f00);
    }

    .bg-red {
      background: linear-gradient(135deg, #ff4b4b, #b80000);
    }

    .bg-purple {
      background: linear-gradient(135deg, #8d35e6, #4e16a8);
    }

    .kpi-label {
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      color: #092869;
      line-height: 1.15;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 39px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .kpi-value.teal {
      color: #0a8a96;
    }

    .kpi-value.orange {
      color: #ff6200;
    }

    .kpi-value.red {
      color: #d90429;
    }

    .kpi-value.purple {
      color: #5b19bd;
    }

    .kpi-note {
      font-size: 13px;
      color: #111;
      line-height: 1.18;
      margin-top: 8px;
      font-weight: 700;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 1.33fr 1fr;
      gap: 18px;
      height: 535px;
      margin-bottom: 10px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11, 45, 92, 0.16);
      overflow: hidden;
    }

    .panel-title {
      height: 46px;
      background: linear-gradient(90deg, #0b3298 0%, #0d5dd4 50%, #11b7bb 100%);
      color: white;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 0 24px;
      font-size: 22px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .panel-title .circle {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      border: 4px solid rgba(255,255,255,0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: -16px;
      background: #0b3298;
      font-size: 27px;
    }

    .chart-box {
      height: 489px;
      padding: 10px 18px 6px 18px;
    }

    .table-box {
      height: 489px;
      padding: 14px 16px 10px 16px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: 15px;
    }

    th {
      background: #092d91;
      color: #ffffff;
      padding: 10px 7px;
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      border: 1px solid #d2dcec;
    }

    td {
      padding: 8px 7px;
      color: #111;
      font-weight: 700;
      border: 1px solid #cfd8e6;
      background: #f8fbff;
      height: 33px;
    }

    tr:nth-child(even) td {
      background: #edf3fb;
    }

    .rank-cell {
      width: 42px;
      text-align: center;
      background: #0b3298 !important;
      color: white;
      font-weight: 900;
    }

    .sum-cell {
      width: auto;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .unit-cell {
      text-align: center;
      font-weight: 900;
      color: #0a8a96;
    }

    .num-cell {
      text-align: center;
      font-weight: 900;
    }

    .pct-cell {
      text-align: center;
      font-weight: 900;
    }

    .total-row td {
      background: #ff6f00 !important;
      color: #000;
      font-weight: 900;
      font-size: 15px;
    }

    .bottom-box {
      height: 105px;
      border: 2px solid #1b65e3;
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 7px 16px rgba(11, 45, 92, 0.10);
      display: grid;
      grid-template-columns: 110px 1fr 190px;
      align-items: center;
      padding: 12px 20px;
      overflow: hidden;
      position: relative;
    }

    .bottom-icon {
      width: 76px;
      height: 76px;
      border-radius: 16px;
      background: linear-gradient(135deg, #0d65df, #06349d);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      box-shadow: 0 8px 16px rgba(11, 45, 92, 0.22);
    }

    .bottom-divider {
      width: 2px;
      height: 72px;
      background: #1b65e3;
      margin-right: 20px;
    }

    .bottom-content {
      display: grid;
      grid-template-columns: 2px 1fr;
      gap: 20px;
      align-items: center;
    }

    .bottom-title {
      color: #092d91;
      font-size: 19px;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .bottom-text {
      font-size: 15px;
      color: #111;
      line-height: 1.25;
    }

    .watermark {
      opacity: 0.06;
      font-size: 100px;
      color: #0b3298;
      text-align: right;
      padding-right: 10px;
    }

    .axis-label {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .bar-value {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .percent-label {
      fill: #08245c;
      font-size: 13px;
      font-weight: 900;
    }

    .legend-text {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .x-label {
      fill: #08245c;
      font-size: 10.5px;
      font-weight: 900;
    }
  </style>
</head>

<body>
<%
  const safeTitulo = typeof titulo !== 'undefined'
    ? titulo
    : 'Yauricocha - Abril 2026 - Suministros en Incidentes';

  const safeLogo = typeof logoText !== 'undefined'
    ? logoText
    : 'COMM';

  const rawItems = typeof items !== 'undefined' && Array.isArray(items)
    ? items
    : [];

  function num(v) {
    return Number(v) || 0;
  }

  function pct(v, t) {
    if (!t) return '0.00%';
    return ((num(v) / num(t)) * 100).toFixed(2) + '%';
  }

  function cortar(txt, n) {
    txt = String(txt || '');
    return txt.length > n ? txt.substring(0, n - 3) + '...' : txt;
  }

  function labelLines(txt) {
    txt = String(txt || '').trim();

    const words = txt.split(/\s+/);
    const lines = [];
    let current = '';

    words.forEach(word => {
      if ((current + ' ' + word).trim().length <= 13) {
        current = (current + ' ' + word).trim();
      } else {
        if (current) lines.push(current);
        current = word;
      }
    });

    if (current) lines.push(current);

    if (lines.length > 3) {
      lines.length = 3;
      lines[2] = lines[2].substring(0, 10) + '...';
    }

    return lines;
  }

  const totalSumInc = num(
    typeof totalSuministrosIncidentes !== 'undefined'
      ? totalSuministrosIncidentes
      : typeof totalSuministros !== 'undefined'
        ? totalSuministros
        : rawItems.reduce((a, b) => a + num(b.cantidad || b.total || b.valor), 0)
  );

  const processedItems = rawItems.slice(0, 10).map(item => {
    const total = num(item.cantidad || item.total || item.valor);

    return {
      nombre: item.nombre || item.descripcion || item.suministro || item.material || '',
      unidad: item.unidad || item.um || item.medida || '-',
      cantidad: total,
      porcentaje: item.porcentaje || pct(total, totalSumInc)
    };
  });

  let acumulado = 0;

  processedItems.forEach(item => {
    acumulado += item.cantidad;
    item.pctAcumulado = totalSumInc ? (acumulado / totalSumInc) * 100 : 0;
  });

  const totalTop10Calc = processedItems.reduce((a, b) => a + b.cantidad, 0);

  const totalTop10Final = num(
    typeof totalTop10 !== 'undefined'
      ? totalTop10
      : totalTop10Calc
  );

  const top1 = processedItems[0] || {
    nombre: '-',
    unidad: '-',
    cantidad: 0,
    porcentaje: '0.00%',
    pctAcumulado: 0
  };

  const top2Cantidad = processedItems
    .slice(0, 2)
    .reduce((a, b) => a + b.cantidad, 0);

  const top3Cantidad = processedItems
    .slice(0, 3)
    .reduce((a, b) => a + b.cantidad, 0);

  const pctTop2Final = typeof pctTop2 !== 'undefined'
    ? pctTop2
    : pct(top2Cantidad, totalSumInc);

  const pctTop3Final = typeof pctTop3 !== 'undefined'
    ? pctTop3
    : pct(top3Cantidad, totalSumInc);

  const maxCantRaw = Math.max(...processedItems.map(i => i.cantidad), 1);
  const maxCant = Math.ceil(maxCantRaw / 10) * 10;

  const chartLeft = 88;
  const chartTop = 58;
  const chartW = 710;
  const chartH = 260;
  const baseY = chartTop + chartH;
  const gap = processedItems.length ? chartW / processedItems.length : chartW;
  const barW = Math.min(48, gap * 0.45);

  const conclusion1 =
    `El suministro de mayor uso en incidentes corresponde a ${top1.nombre}.`;

  const conclusion2 =
    `El Top 3 representa ${pctTop3Final} del total de suministros en incidentes.`;
%>

<div class="slide">
  <div class="corner"></div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= safeTitulo %></div>
    </div>

    <div class="logo">
      <div class="logo-symbol"></div>
      <div><%= safeLogo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▦</div>
      <div>
        <div class="kpi-label">Total Suministros en Incidentes</div>
        <div class="kpi-value"><%= totalSumInc %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">#</div>
      <div>
        <div class="kpi-label">Categorías Top</div>
        <div class="kpi-value teal"><%= processedItems.length %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange">▥</div>
      <div>
        <div class="kpi-label">Principal Suministro</div>
        <div class="kpi-value orange"><%= top1.cantidad %></div>
        <div class="kpi-note"><%= cortar(top1.nombre, 35) %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-red">%</div>
      <div>
        <div class="kpi-label">% Principal Suministro</div>
        <div class="kpi-value red"><%= top1.porcentaje %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">2</div>
      <div>
        <div class="kpi-label">Top 2 Participación</div>
        <div class="kpi-value teal"><%= pctTop2Final %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue">3</div>
      <div>
        <div class="kpi-label">Top 3 Participación</div>
        <div class="kpi-value"><%= pctTop3Final %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <div class="panel">
      <div class="panel-title">
        <div class="circle">↗</div>
        Pareto de Suministros en Incidentes
      </div>

      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 850 440" preserveAspectRatio="none">

          <rect x="165" y="18" width="22" height="11" fill="#0b43bf"></rect>
          <text x="196" y="30" class="legend-text">Cantidad (Suministros)</text>

          <line x1="420" y1="24" x2="460" y2="24" stroke="#ff6400" stroke-width="4"></line>
          <circle cx="440" cy="24" r="5" fill="#ff6400"></circle>
          <text x="470" y="30" class="legend-text">% Acumulado</text>

          <% [0, 0.25, 0.50, 0.75, 1].forEach(p => {
            const y = baseY - p * chartH;
            const val = Math.round(maxCant * p);
          %>
            <line x1="<%= chartLeft %>" y1="<%= y %>" x2="<%= chartLeft + chartW %>" y2="<%= y %>" stroke="#cfd8e6" stroke-width="1" stroke-dasharray="4 4"></line>
            <text x="55" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <% [0, 20, 40, 60, 80, 100].forEach(v => {
            const y = baseY - (v / 100) * chartH;
          %>
            <text x="812" y="<%= y + 5 %>" text-anchor="end" class="axis-label"><%= v %>%</text>
          <% }) %>

          <text x="20" y="210" transform="rotate(-90 20,210)" class="axis-label">CANTIDAD</text>

          <% processedItems.forEach((item, i) => {
            const xCenter = chartLeft + i * gap + gap / 2;
            const x = xCenter - barW / 2;
            const barH = maxCant ? (item.cantidad / maxCant) * chartH : 0;
            const y = baseY - barH;
          %>
            <rect x="<%= x %>" y="<%= y %>" width="<%= barW %>" height="<%= barH %>" fill="#0b43bf" rx="3"></rect>
            <text x="<%= xCenter %>" y="<%= y - 8 %>" text-anchor="middle" class="bar-value"><%= item.cantidad %></text>
          <% }) %>

          <polyline
            fill="none"
            stroke="#ff6400"
            stroke-width="4"
            points="
              <% processedItems.forEach((item, i) => {
                const xCenter = chartLeft + i * gap + gap / 2;
                const y = baseY - (item.pctAcumulado / 100) * chartH;
              %>
                <%= xCenter %>,<%= y %>
              <% }) %>
            "
          />

          <% processedItems.forEach((item, i) => {
            const xCenter = chartLeft + i * gap + gap / 2;
            const y = baseY - (item.pctAcumulado / 100) * chartH;
          %>
            <circle cx="<%= xCenter %>" cy="<%= y %>" r="5" fill="#ff6400"></circle>
            <text x="<%= xCenter %>" y="<%= y - 12 %>" text-anchor="middle" class="percent-label">
              <%= item.pctAcumulado.toFixed(2) %>%
            </text>
          <% }) %>

          <line x1="<%= chartLeft %>" y1="<%= baseY %>" x2="<%= chartLeft + chartW %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>
          <line x1="<%= chartLeft %>" y1="<%= chartTop %>" x2="<%= chartLeft %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>
          <line x1="<%= chartLeft + chartW %>" y1="<%= chartTop %>" x2="<%= chartLeft + chartW %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>

          <% processedItems.forEach((item, i) => {
            const xCenter = chartLeft + i * gap + gap / 2;
            const lines = labelLines(item.nombre);
          %>
            <text x="<%= xCenter %>" y="354" text-anchor="middle" class="x-label">
              <% lines.forEach((line, idx) => { %>
                <tspan x="<%= xCenter %>" dy="<%= idx === 0 ? 0 : 14 %>"><%= line %></tspan>
              <% }) %>
            </text>
          <% }) %>
        </svg>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">
        <div class="circle">▤</div>
        Detalle Suministros en Incidentes
      </div>

      <div class="table-box">
        <table>
          <thead>
            <tr>
              <th style="width:45px;">#</th>
              <th>Suministro</th>
              <th style="width:82px;">Unidad</th>
              <th style="width:92px;">Cantidad</th>
              <th style="width:82px;">%</th>
            </tr>
          </thead>

          <tbody>
            <% processedItems.forEach((item, i) => { %>
              <tr>
                <td class="rank-cell"><%= i + 1 %></td>
                <td class="sum-cell"><%= item.nombre %></td>
                <td class="unit-cell"><%= item.unidad || '-' %></td>
                <td class="num-cell"><%= item.cantidad %></td>
                <td class="pct-cell"><%= item.porcentaje %></td>
              </tr>
            <% }) %>

            <tr class="total-row">
              <td colspan="2">TOTAL GENERAL</td>
              <td class="unit-cell">-</td>
              <td class="num-cell"><%= totalSumInc %></td>
              <td class="pct-cell">100.00%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="bottom-box">
    <div class="bottom-icon">▦</div>

    <div class="bottom-content">
      <div class="bottom-divider"></div>

      <div>
        <div class="bottom-title">Suministros usados en incidentes</div>
        <div class="bottom-text">
          <%= conclusion1 %><br>
          <%= conclusion2 %>
        </div>
      </div>
    </div>

    <div class="watermark">↗</div>
  </div>
</div>
</body>
</html>
