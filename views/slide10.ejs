<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 10 Premium</title>
  <link rel="stylesheet" href="/public/styles.css" />

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #ffffff;
    }

    .canvas {
      width: 1600px;
      height: 900px;
      padding: 18px 26px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
      position: relative;
      overflow: hidden;
    }

    .corner-ribbon {
      position: absolute;
      right: 0;
      top: 0;
      width: 325px;
      height: 80px;
      background: linear-gradient(135deg, #06328f, #0b63df);
      border-bottom-left-radius: 120px;
      z-index: 0;
    }

    .slide-title-row {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .title-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .title-accent {
      width: 12px;
      height: 52px;
      background: #145fe0;
      border-radius: 4px;
    }

    .main-title {
      font-size: 37px;
      font-weight: 900;
      color: #062a63;
      letter-spacing: 0.2px;
      margin: 0;
      text-transform: uppercase;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 14px;
      color: white;
      font-size: 36px;
      font-weight: 900;
      z-index: 3;
      padding-right: 22px;
    }

    .logo-dot {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #55d9ff, #0b4fc7);
      border: 3px solid rgba(255,255,255,0.75);
    }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 16px;
      margin-bottom: 15px;
    }

    .kpi {
      height: 105px;
      background: #ffffff;
      border: 1px solid #d6e2f2;
      border-radius: 14px;
      box-shadow: 0 6px 14px rgba(10, 45, 91, 0.13);
      padding: 15px 15px;
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 14px;
      align-items: center;
    }

    .kpi-icon {
      width: 66px;
      height: 66px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 31px;
      font-weight: 900;
    }

    .blue { background: linear-gradient(135deg, #0b5ed7, #0640a5); }
    .teal { background: linear-gradient(135deg, #08b9bd, #07878f); }
    .orange { background: linear-gradient(135deg, #ffb000, #ff6200); }
    .purple { background: linear-gradient(135deg, #8d48e8, #6125c9); }

    .kpi-label {
      font-size: 13px;
      line-height: 1.15;
      color: #08275c;
      font-weight: 900;
      text-transform: uppercase;
      min-height: 30px;
    }

    .kpi-value {
      font-size: 39px;
      font-weight: 900;
      line-height: 1;
      margin-top: 4px;
    }

    .value-blue { color: #145fe0; }
    .value-teal { color: #07939b; }
    .value-orange { color: #ff6200; }
    .value-purple { color: #6f35d8; }

    .main-chart {
      height: 462px;
      background: #ffffff;
      border: 1px solid #d6e2f2;
      border-radius: 16px;
      box-shadow: 0 7px 18px rgba(10, 45, 91, 0.13);
      overflow: hidden;
      margin-bottom: 17px;
    }

    .chart-title {
      height: 40px;
      background: linear-gradient(90deg, #0b3298 0%, #0b5ed7 55%, #12b8c8 100%);
      color: white;
      font-size: 19px;
      font-weight: 900;
      display: flex;
      align-items: center;
      padding: 0 24px;
      text-transform: uppercase;
    }

    .chart-area {
      height: 422px;
      padding: 14px 24px 4px 24px;
    }

    .bottom-row {
      display: grid;
      grid-template-columns: 1fr 0.62fr 1.02fr;
      gap: 20px;
      height: 145px;
    }

    .bottom-card {
      background: #ffffff;
      border: 1px solid #0b5ed7;
      border-radius: 14px;
      box-shadow: 0 5px 13px rgba(10, 45, 91, 0.10);
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 18px;
      overflow: hidden;
    }

    .bottom-card.teal-border {
      border-color: #13aeb5;
    }

    .bottom-card.dark {
      background: linear-gradient(120deg, #06328f 0%, #0c62d9 55%, #12b8c8 100%);
      border-color: transparent;
      color: white;
      display: block;
      padding: 16px 26px;
    }

    .big-icon {
      width: 80px;
      height: 80px;
      border-radius: 17px;
      color: white;
      font-size: 39px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      background: linear-gradient(135deg, #0b5ed7, #13b7c3);
    }

    .bottom-title {
      font-size: 21px;
      font-weight: 900;
      color: #0b3298;
      margin-bottom: 8px;
    }

    .bottom-desc {
      font-size: 15px;
      line-height: 1.45;
      color: #0a2354;
    }

    .data-list {
      font-size: 17px;
      color: #08275c;
      line-height: 1.5;
    }

    .data-list b {
      color: #0b3298;
      float: right;
      padding-left: 40px;
    }

    .insights-title {
      color: white;
      font-size: 22px;
      font-weight: 900;
      margin-bottom: 11px;
      text-transform: uppercase;
    }

    .insight-line {
      display: grid;
      grid-template-columns: 34px 1fr;
      align-items: center;
      gap: 12px;
      font-size: 15.2px;
      line-height: 1.32;
      margin-bottom: 10px;
      border-bottom: 1px dashed rgba(255,255,255,0.35);
      padding-bottom: 8px;
    }

    .insight-line:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .small-badge {
      width: 31px;
      height: 31px;
      border-radius: 50%;
      background: rgba(255,255,255,0.95);
      color: #0b5ed7;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 900;
    }

    .axis-label {
      font-size: 14px;
      fill: #08275c;
      font-weight: 800;
    }

    .date-label {
      font-size: 10.2px;
      fill: #08275c;
      font-weight: 700;
    }

    .bar-num-dark {
      font-size: 13px;
      fill: #ffffff;
      font-weight: 900;
    }

    .bar-num-light {
      font-size: 13px;
      fill: #071b3a;
      font-weight: 900;
    }

    .legend-text {
      font-size: 15px;
      fill: #08275c;
      font-weight: 800;
    }
  </style>
</head>

<body>
<%
  const data = Array.isArray(dias) && dias.length ? dias : [];

  const totalAt = Number(totalAtenciones || 0);
  const totalHr = Number(totalHoras || 0);
  const diasCount = Number(diasConAtencion || diasPeriodo || data.length || 0);

  const promAt = promedioAtencionesDia || (diasCount ? (totalAt / diasCount).toFixed(1) : '0.0');
  const promHr = promedioHorasDia || (diasCount ? (totalHr / diasCount).toFixed(1) : '0.0');
  const hpa = horasPorAtencion || (totalAt ? (totalHr / totalAt).toFixed(2) : '0.00');

  const maxStackRaw = Math.max(...data.map(d => (Number(d.atenciones)||0) + (Number(d.horas)||0)), 1);
  const maxStack = Math.ceil(maxStackRaw / 5) * 5;

  const chartW = 1480;
  const left = 62;
  const base = 242;
  const usableW = 1368;
  const usableH = 220;

  const gap = data.length ? usableW / data.length : usableW;
  const barW = Math.min(32, gap * 0.60);

  const insightsFinal = Array.isArray(insights) && insights.length
    ? insights
    : [
      insight || 'Volumen total significativo de actividad operativa.',
      'Estabilidad operativa con picos controlados de demanda.',
      'Monitoreo continuo para mantener la calidad del servicio.'
    ];

  function fechaCorta(d) {
    const valor = String(d.fecha || d.dia || '').trim();

    if (!valor) return '';

    // Si viene como 01/04/2026, mantenerlo.
    if (/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(valor)) {
      return valor;
    }

    // Si viene como fecha de Google o texto largo, usar el valor tal cual.
    return valor;
  }
%>

<div class="canvas">
  <div class="corner-ribbon"></div>

  <div class="slide-title-row">
    <div class="title-left">
      <div class="title-accent"></div>
      <h1 class="main-title"><%= titulo || 'ATENCIONES EN LA OPERACIÓN YAURICOCHA - PERIODO' %></h1>
    </div>

    <div class="logo-area">
      <div class="logo-dot"></div>
      <div><%= logoText || 'COMM' %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi">
      <div class="kpi-icon blue">▣</div>
      <div>
        <div class="kpi-label">DÍAS</div>
        <div class="kpi-value value-blue"><%= diasCount %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon teal">●●●</div>
      <div>
        <div class="kpi-label">ATENCIONES</div>
        <div class="kpi-value value-teal"><%= totalAt %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon blue">◷</div>
      <div>
        <div class="kpi-label">HORAS</div>
        <div class="kpi-value value-blue"><%= totalHr %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon orange">▥</div>
      <div>
        <div class="kpi-label">PROMEDIO DE ATENCIONES POR DÍA</div>
        <div class="kpi-value value-orange"><%= promAt %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon purple">◷</div>
      <div>
        <div class="kpi-label">PROMEDIO DE HORAS POR DÍA</div>
        <div class="kpi-value value-purple"><%= promHr %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon teal">▦</div>
      <div>
        <div class="kpi-label">HORAS POR ATENCIÓN</div>
        <div class="kpi-value value-teal"><%= hpa %></div>
      </div>
    </div>
  </div>

  <div class="main-chart">
    <div class="chart-title">ATENCIONES Y HORAS DIARIAS - <%= (periodo || '').toUpperCase() %></div>

    <div class="chart-area">
      <svg width="100%" height="100%" viewBox="0 0 1480 392" preserveAspectRatio="none">

        <!-- Etiqueta eje Y -->
        <text x="16" y="165" transform="rotate(-90 16,165)" class="axis-label">CANTIDAD</text>

        <!-- Grid y eje Y -->
        <% [0, 0.25, 0.5, 0.75, 1].forEach((p) => {
          const y = base - p * usableH;
          const val = Math.round(maxStack * p);
        %>
          <line x1="<%= left %>" y1="<%= y %>" x2="1455" y2="<%= y %>" stroke="#dce6f3" stroke-width="1" stroke-dasharray="4 4" />
          <text x="30" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
        <% }) %>

        <!-- Barras apiladas -->
        <% data.forEach((d, i) => {
          const at = Number(d.atenciones) || 0;
          const hr = Number(d.horas) || 0;

          const xCenter = left + i * gap + gap / 2;
          const x = xCenter - barW / 2;

          const atH = (at / maxStack) * usableH;
          const hrH = (hr / maxStack) * usableH;

          const yAt = base - atH;
          const yHr = yAt - hrH;

          const label = fechaCorta(d);
        %>
          <rect x="<%= x %>" y="<%= yAt %>" width="<%= barW %>" height="<%= atH %>" fill="#073fb4" rx="2" />
          <rect x="<%= x %>" y="<%= yHr %>" width="<%= barW %>" height="<%= hrH %>" fill="#a9c9ff" rx="2" />

          <% if (atH > 14) { %>
            <text x="<%= xCenter %>" y="<%= yAt + atH / 2 + 5 %>" text-anchor="middle" class="bar-num-dark"><%= at %></text>
          <% } %>

          <% if (hrH > 14) { %>
            <text x="<%= xCenter %>" y="<%= yHr + hrH / 2 + 5 %>" text-anchor="middle" class="bar-num-light"><%= hr %></text>
          <% } %>

          <!-- Fechas: zona separada, no toca la leyenda -->
          <text
            x="<%= xCenter - 2 %>"
            y="300"
            text-anchor="end"
            transform="rotate(-48 <%= xCenter %>,300)"
            class="date-label"
          >
            <%= label %>
          </text>
        <% }) %>

        <!-- Leyenda en zona inferior separada -->
        <rect x="618" y="365" width="14" height="14" fill="#073fb4" />
        <text x="640" y="377" class="legend-text">Atenciones</text>

        <rect x="780" y="365" width="14" height="14" fill="#a9c9ff" />
        <text x="802" y="377" class="legend-text">Horas</text>

      </svg>
    </div>
  </div>

  <div class="bottom-row">
    <div class="bottom-card">
      <div class="big-icon">↗</div>
      <div>
        <div class="bottom-title">Tendencia de Atenciones Diarias</div>
        <div class="bottom-desc">
          Distribución diaria de atenciones, mostrando estabilidad operativa y picos controlados de demanda a lo largo del mes.
        </div>
      </div>
    </div>

    <div class="bottom-card teal-border">
      <div class="big-icon">▤</div>
      <div style="width:100%;">
        <div class="bottom-title">Datos de Atenciones Diarias</div>
        <div class="data-list">
          DÍAS: <b><%= diasCount %></b><br>
          ATENCIONES: <b><%= totalAt %></b><br>
          HORAS: <b><%= totalHr %></b>
        </div>
      </div>
    </div>

    <div class="bottom-card dark">
      <div class="insights-title">INSIGHTS EJECUTIVOS</div>

      <% insightsFinal.slice(0,3).forEach((txt, idx) => { %>
        <div class="insight-line">
          <div class="small-badge"><%= idx === 0 ? '●' : idx === 1 ? '✓' : '⌕' %></div>
          <div><%= txt %></div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
</body>
</html>
