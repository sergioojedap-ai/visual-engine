<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 13 - Detalle de Requerimientos e Incidentes</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #eef4fb;
    }

    .slide {
      width: 1600px;
      height: 900px;
      background: linear-gradient(180deg, #ffffff 0%, #f5f9ff 100%);
      color: #08245c;
      overflow: hidden;
      position: relative;
      padding: 22px 24px 0 24px;
    }

    .top-curve {
      position: absolute;
      top: 0;
      right: 0;
      width: 360px;
      height: 86px;
      background: linear-gradient(135deg, #0d65df 0%, #082d91 100%);
      border-bottom-left-radius: 105px;
      z-index: 0;
    }

    .header {
      position: relative;
      z-index: 2;
      height: 66px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .title-wrap {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .title-bar {
      width: 14px;
      height: 50px;
      background: linear-gradient(180deg, #0d65df, #13b7ba);
    }

    .title {
      font-size: 38px;
      font-weight: 900;
      color: #071f5c;
      letter-spacing: -0.6px;
    }

    .logo {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 12px;
      color: #ffffff;
      font-size: 39px;
      font-weight: 900;
      padding-right: 22px;
    }

    .logo-symbol {
      width: 50px;
      height: 30px;
      border-radius: 50%;
      border: 5px dashed rgba(255,255,255,0.85);
      transform: rotate(-18deg);
    }

    .kpi-row {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 14px;
      margin-bottom: 16px;
    }

    .kpi-card {
      height: 124px;
      background: #ffffff;
      border: 1px solid #d2dceb;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.16);
      display: grid;
      grid-template-columns: 82px 1fr;
      align-items: center;
      gap: 13px;
      padding: 14px 14px;
    }

    .kpi-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 35px;
      font-weight: 900;
      box-shadow: 0 9px 16px rgba(0,0,0,0.16);
    }

    .bg-blue {
      background: linear-gradient(135deg, #1264df, #06339b);
    }

    .bg-teal {
      background: linear-gradient(135deg, #1ac4c6, #087a87);
    }

    .bg-orange {
      background: linear-gradient(135deg, #ffb51d, #ff5f00);
    }

    .bg-purple {
      background: linear-gradient(135deg, #9542e8, #5520aa);
    }

    .kpi-label {
      font-size: 13px;
      font-weight: 900;
      color: #092869;
      line-height: 1.18;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 38px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .kpi-value.teal {
      color: #0a8a96;
    }

    .kpi-value.orange {
      color: #ff6200;
    }

    .kpi-value.purple {
      color: #6a25d3;
    }

    .main-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 0.36fr 0.64fr;
      gap: 16px;
      height: 515px;
      margin-bottom: 14px;
    }

    .left-stack {
      display: grid;
      grid-template-rows: 165px 1fr;
      gap: 14px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.16);
      overflow: hidden;
    }

    .insight-card {
      display: grid;
      grid-template-columns: 115px 1fr;
      align-items: center;
      padding: 20px 24px;
      border-left: 10px solid #0d65df;
    }

    .insight-icon-main {
      width: 82px;
      height: 82px;
      border-radius: 18px;
      background: linear-gradient(135deg, #1264df, #06339b);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 46px;
      font-weight: 900;
      box-shadow: 0 8px 18px rgba(11,45,92,0.20);
    }

    .insight-title-small {
      font-size: 25px;
      font-weight: 900;
      color: #092d91;
      margin-bottom: 10px;
    }

    .insight-text-small {
      font-size: 18px;
      line-height: 1.38;
      color: #0a1b44;
    }

    .check {
      color: #0ba88e;
      font-weight: 900;
      margin-right: 9px;
    }

    .donut-panel {
      padding: 12px 20px 6px 20px;
    }

    .donut-title {
      text-align: center;
      font-size: 21px;
      font-weight: 900;
      color: #092d91;
      text-transform: uppercase;
      margin-bottom: 0;
    }

    .line-panel {
      padding: 18px 24px 10px 24px;
    }

    .line-title {
      text-align: center;
      font-size: 22px;
      font-weight: 900;
      color: #092d91;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .bottom-box {
      position: relative;
      z-index: 2;
      height: 105px;
      border: 2px solid #1b65e3;
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 7px 16px rgba(11,45,92,0.10);
      display: grid;
      grid-template-columns: 125px 270px 2px 1fr 200px;
      align-items: center;
      padding: 12px 22px;
      overflow: hidden;
    }

    .bottom-icon {
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0d65df, #06349d);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      box-shadow: 0 8px 16px rgba(11,45,92,0.22);
    }

    .bottom-title {
      color: #0d55d8;
      font-size: 25px;
      font-weight: 900;
    }

    .bottom-divider {
      width: 2px;
      height: 70px;
      background: #b6c0d0;
    }

    .bottom-text {
      padding-left: 34px;
      font-size: 19px;
      line-height: 1.32;
      color: #0a1b44;
    }

    .bottom-graphic {
      text-align: center;
      font-size: 82px;
      color: #0ba88e;
      opacity: 0.95;
    }

    .axis-label {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .line-label-blue {
      fill: #0b43bf;
      font-size: 15px;
      font-weight: 900;
    }

    .line-label-orange {
      fill: #ff5f00;
      font-size: 15px;
      font-weight: 900;
    }

    .legend-text {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .month-label {
      fill: #08245c;
      font-size: 14px;
      font-weight: 800;
    }

    .donut-center {
      fill: #08245c;
      font-weight: 900;
      text-anchor: middle;
    }

    .donut-side-blue {
      fill: #0b43bf;
      font-size: 26px;
      font-weight: 900;
    }

    .donut-side-orange {
      fill: #ff5f00;
      font-size: 26px;
      font-weight: 900;
    }
  </style>
</head>

<body>
<%
  const safeLogo = typeof logoText !== 'undefined' ? logoText : 'COMM';

  function num(v) {
    return Number(v) || 0;
  }

  function pct(v, t) {
    if (!t) return '0%';
    return Math.round((num(v) / num(t)) * 100) + '%';
  }

  function oneDecimal(v, t) {
    if (!t) return '0.0';
    return (num(v) / num(t)).toFixed(1);
  }

  const periodoFinal = typeof periodo !== 'undefined' ? periodo : 'Abril 2026';

  const tituloFinal = typeof titulo !== 'undefined'
    ? titulo
    : `Yauricocha - ${periodoFinal} - Detalle de Requerimientos e Incidentes`;

  const rawMeses = typeof meses !== 'undefined' && Array.isArray(meses)
    ? meses
    : [];

  let dataMeses = rawMeses.map(item => ({
    mes: item.mes || item.periodo || '',
    incidentes: num(item.incidentes || item.incidente || item.inc),
    requerimientos: num(item.requerimientos || item.requerimiento || item.req)
  })).filter(item => item.mes);

  if (!dataMeses.length) {
    dataMeses = [
      { mes: 'Jul-25', incidentes: 81, requerimientos: 176 },
      { mes: 'Ago-25', incidentes: 77, requerimientos: 180 },
      { mes: 'Set-25', incidentes: 81, requerimientos: 190 },
      { mes: 'Oct-25', incidentes: 100, requerimientos: 178 },
      { mes: 'Nov-25', incidentes: 90, requerimientos: 224 },
      { mes: 'Dic-25', incidentes: 73, requerimientos: 216 },
      { mes: 'Ene-26', incidentes: 47, requerimientos: 82 },
      { mes: 'Feb-26', incidentes: 50, requerimientos: 90 },
      { mes: 'Mar-26', incidentes: 53, requerimientos: 113 },
      { mes: 'Abr-26', incidentes: 39, requerimientos: 120 }
    ];
  }

  const totalReq = num(
    typeof totalRequerimientos !== 'undefined'
      ? totalRequerimientos
      : dataMeses.reduce((a, b) => a + b.requerimientos, 0)
  );

  const totalInc = num(
    typeof totalIncidentes !== 'undefined'
      ? totalIncidentes
      : dataMeses.reduce((a, b) => a + b.incidentes, 0)
  );

  const totalAt = num(
    typeof totalAtenciones !== 'undefined'
      ? totalAtenciones
      : totalReq + totalInc
  );

  const pctReq = typeof participacionRequerimientos !== 'undefined'
    ? participacionRequerimientos
    : pct(totalReq, totalAt);

  const pctInc = typeof participacionIncidentes !== 'undefined'
    ? participacionIncidentes
    : pct(totalInc, totalAt);

  const promedioMensual = typeof promedioMensualTotal !== 'undefined'
    ? promedioMensualTotal
    : oneDecimal(totalAt, dataMeses.length);

  const insightFinal = typeof insight !== 'undefined'
    ? insight
    : `La gestión operativa se mantiene eficiente, con una alta participación de requerimientos (${pctReq}) frente a incidentes (${pctInc}), lo que evidencia un entorno controlado y predecible.`;

  const maxLine = Math.ceil(Math.max(...dataMeses.map(i => Math.max(i.incidentes, i.requerimientos)), 1) / 50) * 50;

  const chartX = 75;
  const chartY = 74;
  const chartW = 850;
  const chartH = 330;
  const baseY = chartY + chartH;
  const gap = chartW / (dataMeses.length - 1 || 1);

  function yLine(v) {
    return baseY - (num(v) / maxLine) * chartH;
  }

  const reqPoints = dataMeses.map((item, i) => {
    const x = chartX + i * gap;
    const y = yLine(item.requerimientos);
    return `${x},${y}`;
  }).join(' ');

  const incPoints = dataMeses.map((item, i) => {
    const x = chartX + i * gap;
    const y = yLine(item.incidentes);
    return `${x},${y}`;
  }).join(' ');

  const reqAngle = totalAt ? (totalReq / totalAt) * 360 : 0;
  const incAngle = 360 - reqAngle;

  const donutCx = 285;
  const donutCy = 155;
  const donutR = 88;
  const donutStroke = 54;
  const donutC = 2 * Math.PI * donutR;
  const reqLen = donutC * (reqAngle / 360);
  const incLen = donutC - reqLen;
%>

<div class="slide">
  <div class="top-curve"></div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= tituloFinal %></div>
    </div>

    <div class="logo">
      <div class="logo-symbol"></div>
      <div><%= safeLogo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▣</div>
      <div>
        <div class="kpi-label">Total<br>Requerimientos</div>
        <div class="kpi-value"><%= totalReq.toLocaleString('en-US') %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">◇</div>
      <div>
        <div class="kpi-label">Total<br>Incidentes</div>
        <div class="kpi-value teal"><%= totalInc.toLocaleString('en-US') %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-purple">●</div>
      <div>
        <div class="kpi-label">Total<br>Atenciones</div>
        <div class="kpi-value purple"><%= totalAt.toLocaleString('en-US') %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange">◔</div>
      <div>
        <div class="kpi-label">Participación de<br>Requerimientos</div>
        <div class="kpi-value orange"><%= pctReq %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue">◇</div>
      <div>
        <div class="kpi-label">Participación de<br>Incidentes</div>
        <div class="kpi-value"><%= pctInc %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">▥</div>
      <div>
        <div class="kpi-label">Promedio Mensual<br>Total</div>
        <div class="kpi-value teal"><%= promedioMensual %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <div class="left-stack">
      <div class="panel insight-card">
        <div class="insight-icon-main">◎</div>
        <div>
          <div class="insight-title-small">Distribución de atenciones</div>
          <div class="insight-text-small">
            <span class="check">●</span>
            El predominio de requerimientos confirma una adecuada planificación de las actividades y una baja exposición a eventos disruptivos.
          </div>
        </div>
      </div>

      <div class="panel donut-panel">
        <div class="donut-title">Total Requerimientos vs Incidentes</div>

        <svg width="100%" height="300" viewBox="0 0 560 300">
          <circle
            cx="<%= donutCx %>"
            cy="<%= donutCy %>"
            r="<%= donutR %>"
            fill="none"
            stroke="#0b43bf"
            stroke-width="<%= donutStroke %>"
          />

          <circle
            cx="<%= donutCx %>"
            cy="<%= donutCy %>"
            r="<%= donutR %>"
            fill="none"
            stroke="#ff6a00"
            stroke-width="<%= donutStroke %>"
            stroke-dasharray="<%= reqLen %> <%= incLen %>"
            stroke-dashoffset="0"
            transform="rotate(-90 <%= donutCx %> <%= donutCy %>)"
          />

          <circle cx="<%= donutCx %>" cy="<%= donutCy %>" r="52" fill="#ffffff"></circle>

          <text x="<%= donutCx %>" y="<%= donutCy - 10 %>" class="donut-center" style="font-size:22px;">
            <%= totalAt.toLocaleString('en-US') %>
          </text>
          <text x="<%= donutCx %>" y="<%= donutCy + 16 %>" class="donut-center" style="font-size:16px;">
            ATENCIONES
          </text>
          <text x="<%= donutCx %>" y="<%= donutCy + 38 %>" class="donut-center" style="font-size:16px;">
            TOTALES
          </text>

          <text x="40" y="145" class="donut-side-orange"><%= totalReq.toLocaleString('en-US') %></text>
          <text x="40" y="175" class="donut-side-orange"><%= pctReq %></text>
          <line x1="108" y1="158" x2="172" y2="158" stroke="#ff6a00" stroke-width="2"></line>

          <text x="442" y="145" class="donut-side-blue"><%= totalInc.toLocaleString('en-US') %></text>
          <text x="442" y="175" class="donut-side-blue"><%= pctInc %></text>
          <line x1="390" y1="150" x2="430" y2="130" stroke="#0b43bf" stroke-width="2"></line>

          <rect x="150" y="270" width="13" height="13" fill="#ff6a00"></rect>
          <text x="173" y="282" class="legend-text">Requerimiento</text>

          <rect x="356" y="270" width="13" height="13" fill="#0b43bf"></rect>
          <text x="379" y="282" class="legend-text">Incidente</text>
        </svg>
      </div>
    </div>

    <div class="panel line-panel">
      <div class="line-title">Evolución Mensual – Incidente vs Requerimiento</div>

      <svg width="100%" height="445" viewBox="0 0 980 445" preserveAspectRatio="none">
        <line x1="425" y1="36" x2="465" y2="36" stroke="#0b43bf" stroke-width="4"></line>
        <circle cx="445" cy="36" r="5" fill="#0b43bf"></circle>
        <text x="476" y="42" class="legend-text">Incidente</text>

        <line x1="585" y1="36" x2="625" y2="36" stroke="#ff5f00" stroke-width="4"></line>
        <circle cx="605" cy="36" r="5" fill="#ff5f00"></circle>
        <text x="636" y="42" class="legend-text">Requerimiento</text>

        <% [0, 0.2, 0.4, 0.6, 0.8, 1].forEach(p => {
          const y = baseY - p * chartH;
          const val = Math.round(maxLine * p);
        %>
          <line x1="<%= chartX %>" y1="<%= y %>" x2="<%= chartX + chartW %>" y2="<%= y %>" stroke="#d6dde8" stroke-width="1" stroke-dasharray="4 4"></line>
          <text x="35" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
        <% }) %>

        <polyline fill="none" stroke="#0b43bf" stroke-width="4" points="<%= incPoints %>"></polyline>
        <polyline fill="none" stroke="#ff5f00" stroke-width="4" points="<%= reqPoints %>"></polyline>

        <% dataMeses.forEach((item, i) => {
          const x = chartX + i * gap;
          const yInc = yLine(item.incidentes);
          const yReq = yLine(item.requerimientos);
        %>
          <circle cx="<%= x %>" cy="<%= yInc %>" r="6" fill="#0b43bf"></circle>
          <circle cx="<%= x %>" cy="<%= yReq %>" r="6" fill="#ff5f00"></circle>

          <text x="<%= x %>" y="<%= yInc - 15 %>" text-anchor="middle" class="line-label-blue"><%= item.incidentes %></text>
          <text x="<%= x %>" y="<%= yReq - 15 %>" text-anchor="middle" class="line-label-orange"><%= item.requerimientos %></text>

          <text x="<%= x %>" y="425" text-anchor="middle" class="month-label"><%= item.mes %></text>
        <% }) %>

        <line x1="<%= chartX %>" y1="<%= baseY %>" x2="<%= chartX + chartW %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>
      </svg>
    </div>
  </div>

  <div class="bottom-box">
    <div class="bottom-icon">↗</div>
    <div class="bottom-title">Resultado Operativo</div>
    <div class="bottom-divider"></div>
    <div class="bottom-text"><%= insightFinal %></div>
    <div class="bottom-graphic">✅</div>
  </div>
</div>
</body>
</html>
