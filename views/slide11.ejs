<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 11 - Atenciones por Tipo y Evolución Mensual</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #eef4fb;
    }

    .slide {
      width: 1600px;
      height: 900px;
      background: linear-gradient(180deg, #ffffff 0%, #f4f8ff 100%);
      color: #08245c;
      overflow: hidden;
      position: relative;
      padding: 24px 30px 0 30px;
    }

    .top-curve {
      position: absolute;
      top: 0;
      right: 0;
      width: 360px;
      height: 86px;
      background: linear-gradient(135deg, #0d65df 0%, #082d91 100%);
      border-bottom-left-radius: 105px;
      z-index: 0;
    }

    .bottom-band {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 100%;
      height: 28px;
      background: linear-gradient(90deg, #082d91 0%, #0d65df 55%, #13b7ba 100%);
      z-index: 0;
    }

    .header {
      position: relative;
      z-index: 2;
      height: 68px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    .title-wrap {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .title-bar {
      width: 14px;
      height: 50px;
      background: linear-gradient(180deg, #0d65df, #13b7ba);
    }

    .title {
      font-size: 36px;
      font-weight: 900;
      color: #071f5c;
      letter-spacing: -0.7px;
    }

    .logo {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 12px;
      color: #ffffff;
      font-size: 39px;
      font-weight: 900;
      padding-right: 22px;
    }

    .logo-symbol {
      width: 50px;
      height: 30px;
      border-radius: 50%;
      border: 5px dashed rgba(255,255,255,0.85);
      transform: rotate(-18deg);
    }

    .kpi-row {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 16px;
      margin-bottom: 22px;
    }

    .kpi-card {
      height: 122px;
      background: #ffffff;
      border: 1px solid #d2dceb;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.17);
      display: grid;
      grid-template-columns: 84px 1fr;
      align-items: center;
      gap: 16px;
      padding: 14px 18px;
    }

    .kpi-icon {
      width: 72px;
      height: 72px;
      border-radius: 18px;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 37px;
      font-weight: 900;
      box-shadow: 0 9px 16px rgba(0,0,0,0.16);
    }

    .bg-blue {
      background: linear-gradient(135deg, #1264df, #06339b);
    }

    .bg-teal {
      background: linear-gradient(135deg, #1ac4c6, #087a87);
    }

    .bg-orange {
      background: linear-gradient(135deg, #ffb51d, #ff5f00);
    }

    .bg-purple {
      background: linear-gradient(135deg, #9542e8, #5520aa);
    }

    .kpi-label {
      font-size: 14px;
      font-weight: 900;
      color: #092869;
      line-height: 1.18;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 42px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .kpi-value.teal {
      color: #0a8a96;
    }

    .kpi-value.orange {
      color: #ff6200;
    }

    .kpi-value.purple {
      color: #7a35d7;
    }

    .main-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      height: 430px;
      margin-bottom: 18px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.16);
      overflow: hidden;
    }

    .panel-title {
      height: 39px;
      background: linear-gradient(90deg, #0b3298 0%, #0d5dd4 50%, #11b7bb 100%);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 21px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .chart-box {
      height: 391px;
      padding: 16px 22px 10px 22px;
    }

    .bottom-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 0.56fr 0.44fr;
      gap: 18px;
      height: 145px;
    }

    .summary-wrap {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 0;
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.16);
      overflow: hidden;
    }

    .summary-icon-box {
      display: flex;
      align-items: center;
      justify-content: center;
      border-right: 1px solid #cddbef;
    }

    .summary-icon {
      width: 76px;
      height: 76px;
      border-radius: 16px;
      background: linear-gradient(135deg, #1264df, #06339b);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 39px;
      font-weight: 900;
      box-shadow: 0 8px 18px rgba(11,45,92,0.20);
    }

    .summary-table-box {
      padding: 0;
    }

    .summary-title {
      height: 39px;
      background: linear-gradient(90deg, #0b3298 0%, #0d5dd4 100%);
      color: #ffffff;
      display: flex;
      align-items: center;
      padding-left: 16px;
      font-size: 21px;
      font-weight: 900;
      text-transform: uppercase;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th {
      background: #0b4fbd;
      color: white;
      border: 1px solid #d2dceb;
      height: 33px;
      font-size: 16px;
      font-weight: 900;
      text-transform: uppercase;
    }

    td {
      border: 1px solid #d2dceb;
      height: 39px;
      background: #f7fbff;
      color: #08245c;
      font-size: 20px;
      font-weight: 900;
      text-align: center;
    }

    .insight-box {
      background: #ffffff;
      border: 2px solid #11a8ac;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11,45,92,0.10);
      display: grid;
      grid-template-columns: 104px 1fr;
      align-items: center;
      padding: 14px 22px;
    }

    .insight-icon {
      width: 76px;
      height: 76px;
      border-radius: 18px;
      background: linear-gradient(135deg, #1ac4c6, #087a87);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 44px;
      font-weight: 900;
      box-shadow: 0 8px 16px rgba(11,45,92,0.18);
    }

    .insight-title {
      font-size: 21px;
      font-weight: 900;
      color: #087a87;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .insight-text {
      color: #08245c;
      font-size: 18px;
      line-height: 1.35;
    }

    .axis-label {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .bar-value {
      fill: #08245c;
      font-size: 18px;
      font-weight: 900;
    }

    .bar-value.orange {
      fill: #ff5f00;
    }

    .x-label {
      fill: #08245c;
      font-size: 16px;
      font-weight: 900;
    }

    .legend-text {
      fill: #08245c;
      font-size: 17px;
      font-weight: 900;
    }
  </style>
</head>

<body>
<%
  const safeLogo = typeof logoText !== 'undefined' ? logoText : 'COMM';

  const rawMeses = typeof meses !== 'undefined' && Array.isArray(meses)
    ? meses
    : typeof mensualItems !== 'undefined' && Array.isArray(mensualItems)
      ? mensualItems
      : [];

  function num(v) {
    return Number(v) || 0;
  }

  function pct(v, t) {
    if (!t) return '0.0%';
    return ((num(v) / num(t)) * 100).toFixed(1) + '%';
  }

  let dataMeses = rawMeses.map(item => {
    const mina = num(item.mina || item.im || item.atencionesMina);
    const superficie = num(item.superficie || item.sup || item.atencionesSuperficie);
    const total = num(item.total || item.atenciones || mina + superficie);

    return {
      mes: item.mes || item.periodo || '',
      mina,
      superficie,
      total
    };
  }).filter(item => item.mes);

  if (!dataMeses.length) {
    dataMeses = [
      { mes: 'Ene-26', mina: 137, superficie: 23, total: 160 },
      { mes: 'Feb-26', mina: 133, superficie: 10, total: 143 },
      { mes: 'Mar-26', mina: 128, superficie: 21, total: 149 },
      { mes: 'Abr-26', mina: 121, superficie: 16, total: 137 }
    ];
  }

  const periodoFinal = typeof periodo !== 'undefined' ? periodo : 'Abril 2026';

  const tituloFinal = typeof titulo !== 'undefined'
    ? titulo
    : `Yauricocha - ${periodoFinal} - Atenciones por Tipo y Evolución Mensual`;

  const totalGeneral = num(
    typeof totalAtenciones !== 'undefined'
      ? totalAtenciones
      : dataMeses.reduce((a, b) => a + b.total, 0)
  );

  const totalMina = num(
    typeof totalMinaGlobal !== 'undefined'
      ? totalMinaGlobal
      : typeof minaAtenciones !== 'undefined'
        ? minaAtenciones
        : dataMeses.reduce((a, b) => a + b.mina, 0)
  );

  const totalSuperficie = num(
    typeof totalSuperficieGlobal !== 'undefined'
      ? totalSuperficieGlobal
      : typeof superficieAtenciones !== 'undefined'
        ? superficieAtenciones
        : dataMeses.reduce((a, b) => a + b.superficie, 0)
  );

  const pctMina = typeof participacionMina !== 'undefined'
    ? participacionMina
    : pct(totalMina, totalGeneral);

  const pctSuperficie = typeof participacionSuperficie !== 'undefined'
    ? participacionSuperficie
    : pct(totalSuperficie, totalGeneral);

  const mesActual = dataMeses[dataMeses.length - 1] || {
    mes: 'Abr-26',
    mina: 0,
    superficie: 0,
    total: 0
  };

  const totalMesActual = num(
    typeof totalMesActualValue !== 'undefined'
      ? totalMesActualValue
      : mesActual.total
  );

  const maxTotal = Math.ceil(Math.max(...dataMeses.map(i => i.total), 1) / 10) * 10;
  const maxTipo = Math.ceil(Math.max(...dataMeses.map(i => Math.max(i.mina, i.superficie)), 1) / 10) * 10;

  const chartTop = 35;
  const chartH = 250;
  const baseY = chartTop + chartH;

  const leftX = 82;
  const leftW = 660;
  const leftGap = leftW / dataMeses.length;
  const leftBarW = 76;

  const rightX = 75;
  const rightW = 670;
  const rightGap = rightW / dataMeses.length;
  const groupedBarW = 45;

  const insightFinal = typeof insight !== 'undefined'
    ? insight
    : `Predominio de atenciones en la operación minera (${pctMina}), evidenciando enfoque en servicios preventivos y controlados.`;
%>

<div class="slide">
  <div class="top-curve"></div>
  <div class="bottom-band"></div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= tituloFinal %></div>
    </div>

    <div class="logo">
      <div class="logo-symbol"></div>
      <div><%= safeLogo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▦</div>
      <div>
        <div class="kpi-label">Total<br>Atenciones</div>
        <div class="kpi-value"><%= totalGeneral %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">●</div>
      <div>
        <div class="kpi-label">Atenciones<br>Mina</div>
        <div class="kpi-value teal"><%= totalMina %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange">⌂</div>
      <div>
        <div class="kpi-label">Atenciones<br>Superficie</div>
        <div class="kpi-value orange"><%= totalSuperficie %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-purple">◔</div>
      <div>
        <div class="kpi-label">Participación<br>Mina</div>
        <div class="kpi-value purple"><%= pctMina %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">◕</div>
      <div>
        <div class="kpi-label">Participación<br>Superficie</div>
        <div class="kpi-value teal"><%= pctSuperficie %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▥</div>
      <div>
        <div class="kpi-label"><%= mesActual.mes.replace('-', ' ') %><br>Total</div>
        <div class="kpi-value"><%= totalMesActual %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <div class="panel">
      <div class="panel-title">Evolución Mensual de Atenciones (Total)</div>

      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 770 360" preserveAspectRatio="none">
          <% [0, 0.25, 0.50, 0.75, 1].forEach(p => {
            const y = baseY - p * chartH;
            const val = Math.round(maxTotal * p);
          %>
            <line x1="<%= leftX %>" y1="<%= y %>" x2="<%= leftX + leftW %>" y2="<%= y %>" stroke="#d6dde8" stroke-width="1" stroke-dasharray="4 4"></line>
            <text x="43" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <text x="22" y="195" transform="rotate(-90 22,195)" class="axis-label">ATENCIONES</text>

          <% dataMeses.forEach((item, i) => {
            const xCenter = leftX + i * leftGap + leftGap / 2;
            const barH = maxTotal ? (item.total / maxTotal) * chartH : 0;
            const x = xCenter - leftBarW / 2;
            const y = baseY - barH;
          %>
            <defs>
              <linearGradient id="gradTotal<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#4f83ff"/>
                <stop offset="100%" stop-color="#0b43bf"/>
              </linearGradient>
            </defs>

            <rect x="<%= x %>" y="<%= y %>" width="<%= leftBarW %>" height="<%= barH %>" fill="url(#gradTotal<%= i %>)"></rect>
            <text x="<%= xCenter %>" y="<%= y - 10 %>" text-anchor="middle" class="bar-value"><%= item.total %></text>
            <text x="<%= xCenter %>" y="340" text-anchor="middle" class="x-label"><%= item.mes %></text>
          <% }) %>

          <line x1="<%= leftX %>" y1="<%= baseY %>" x2="<%= leftX + leftW %>" y2="<%= baseY %>" stroke="#c5cfdf" stroke-width="2"></line>
        </svg>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">Atenciones por Tipo (IM vs SUP) – Evolución Mensual</div>

      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 770 360" preserveAspectRatio="none">
          <% [0, 0.25, 0.50, 0.75, 1].forEach(p => {
            const y = baseY - p * chartH;
            const val = Math.round(maxTipo * p);
          %>
            <line x1="<%= rightX %>" y1="<%= y %>" x2="<%= rightX + rightW %>" y2="<%= y %>" stroke="#d6dde8" stroke-width="1" stroke-dasharray="4 4"></line>
            <text x="38" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <text x="22" y="195" transform="rotate(-90 22,195)" class="axis-label">ATENCIONES</text>

          <% dataMeses.forEach((item, i) => {
            const xCenter = rightX + i * rightGap + rightGap / 2;

            const minaH = maxTipo ? (item.mina / maxTipo) * chartH : 0;
            const supH = maxTipo ? (item.superficie / maxTipo) * chartH : 0;

            const minaX = xCenter - groupedBarW - 6;
            const supX = xCenter + 6;

            const minaY = baseY - minaH;
            const supY = baseY - supH;
          %>
            <defs>
              <linearGradient id="gradMina<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#4f83ff"/>
                <stop offset="100%" stop-color="#0b43bf"/>
              </linearGradient>

              <linearGradient id="gradSup<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ff9c2a"/>
                <stop offset="100%" stop-color="#ff5f00"/>
              </linearGradient>
            </defs>

            <rect x="<%= minaX %>" y="<%= minaY %>" width="<%= groupedBarW %>" height="<%= minaH %>" fill="url(#gradMina<%= i %>)"></rect>
            <rect x="<%= supX %>" y="<%= supY %>" width="<%= groupedBarW %>" height="<%= supH %>" fill="url(#gradSup<%= i %>)"></rect>

            <text x="<%= minaX + groupedBarW / 2 %>" y="<%= minaY - 10 %>" text-anchor="middle" class="bar-value"><%= item.mina %></text>
            <text x="<%= supX + groupedBarW / 2 %>" y="<%= supY - 10 %>" text-anchor="middle" class="bar-value orange"><%= item.superficie %></text>

            <text x="<%= xCenter %>" y="326" text-anchor="middle" class="x-label"><%= item.mes %></text>
          <% }) %>

         <rect x="312" y="344" width="12" height="12" fill="#0b43bf"></rect>
<text x="334" y="356" class="legend-text">IM</text>

<rect x="405" y="344" width="12" height="12" fill="#ff5f00"></rect>
<text x="427" y="356" class="legend-text">SUP</text>

          <line x1="<%= rightX %>" y1="<%= baseY %>" x2="<%= rightX + rightW %>" y2="<%= baseY %>" stroke="#c5cfdf" stroke-width="2"></line>
        </svg>
      </div>
    </div>
  </div>

  <div class="bottom-grid">
    <div class="summary-wrap">
      <div class="summary-icon-box">
        <div class="summary-icon">▣</div>
      </div>

      <div class="summary-table-box">
        <div class="summary-title">Resumen <%= periodoFinal %></div>

        <table>
          <thead>
            <tr>
              <th rowspan="2" style="width:18%;">UP</th>
              <th colspan="2">Atenciones</th>
              <th rowspan="2" style="width:18%;">Total</th>
              <th rowspan="2" style="width:18%;">%</th>
            </tr>
            <tr>
              <th>Mina</th>
              <th>Superficie</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>TOTAL</td>
              <td><%= totalMina %></td>
              <td><%= totalSuperficie %></td>
              <td><%= totalGeneral %></td>
              <td>100%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="insight-box">
      <div class="insight-icon">💡</div>

      <div>
        <div class="insight-title">Insight Principal</div>
        <div class="insight-text"><%= insightFinal %></div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
