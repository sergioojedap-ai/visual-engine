<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 11 - Atenciones Mina vs Superficie</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #eef4fb;
    }

    .slide {
      width: 1600px;
      height: 900px;
      background: linear-gradient(180deg, #ffffff 0%, #f3f8ff 100%);
      color: #08245c;
      overflow: hidden;
      position: relative;
      padding: 18px 24px 16px 24px;
    }

    .corner {
      position: absolute;
      right: 0;
      top: 0;
      width: 330px;
      height: 86px;
      background: linear-gradient(135deg, #082b85, #0c4bc0);
      border-bottom-left-radius: 95px;
      z-index: 0;
    }

    .header {
      position: relative;
      z-index: 2;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .title-wrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .title-bar {
      width: 12px;
      height: 56px;
      border-radius: 5px;
      background: #1565df;
    }

    .title {
      font-size: 42px;
      font-weight: 900;
      color: #071f5c;
      letter-spacing: -0.5px;
      text-transform: uppercase;
    }

    .logo {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 14px;
      color: white;
      font-size: 38px;
      font-weight: 900;
      padding-right: 28px;
    }

    .logo-symbol {
      width: 44px;
      height: 26px;
      border-radius: 50%;
      border: 4px dashed rgba(255,255,255,0.85);
      transform: rotate(-18deg);
    }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 14px;
      margin-bottom: 16px;
    }

    .kpi-card {
      height: 122px;
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 16px;
      box-shadow: 0 6px 14px rgba(11, 45, 92, 0.16);
      display: grid;
      grid-template-columns: 76px 1fr;
      gap: 14px;
      align-items: center;
      padding: 14px 16px;
    }

    .kpi-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 34px;
      font-weight: 900;
      box-shadow: 0 8px 16px rgba(0,0,0,0.16);
    }

    .bg-blue {
      background: linear-gradient(135deg, #1264df, #06339b);
    }

    .bg-teal {
      background: linear-gradient(135deg, #18c4c7, #087a87);
    }

    .bg-orange {
      background: linear-gradient(135deg, #ffb51d, #ff5f00);
    }

    .bg-purple {
      background: linear-gradient(135deg, #8d35e6, #4e16a8);
    }

    .kpi-label {
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      color: #092869;
      line-height: 1.15;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 39px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .kpi-value.teal {
      color: #0a8a96;
    }

    .kpi-value.orange {
      color: #ff6200;
    }

    .kpi-value.purple {
      color: #5b19bd;
    }

    .kpi-note {
      font-size: 13px;
      color: #111;
      line-height: 1.18;
      margin-top: 8px;
      font-weight: 700;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 1.25fr 1fr;
      gap: 18px;
      height: 535px;
      margin-bottom: 10px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(11, 45, 92, 0.16);
      overflow: hidden;
    }

    .panel-title {
      height: 46px;
      background: linear-gradient(90deg, #0b3298 0%, #0d5dd4 50%, #11b7bb 100%);
      color: white;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 0 24px;
      font-size: 22px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .panel-title .circle {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      border: 4px solid rgba(255,255,255,0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: -16px;
      background: #0b3298;
      font-size: 27px;
    }

    .chart-box {
      height: 489px;
      padding: 18px 22px 14px 22px;
    }

    .right-content {
      height: 489px;
      padding: 18px 18px 14px 18px;
      display: grid;
      grid-template-rows: 220px 1fr;
      gap: 16px;
    }

    .mini-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .mini-card {
      background: #f8fbff;
      border: 1px solid #cfd8e6;
      border-radius: 16px;
      padding: 14px 16px;
      box-shadow: 0 6px 12px rgba(11,45,92,0.10);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .mini-title {
      font-size: 17px;
      font-weight: 900;
      color: #092d91;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .mini-value {
      font-size: 46px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .mini-value.orange {
      color: #ff6200;
    }

    .mini-detail {
      margin-top: 10px;
      font-size: 15px;
      color: #111;
      font-weight: 800;
      line-height: 1.25;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: 15.5px;
    }

    th {
      background: #092d91;
      color: #ffffff;
      padding: 10px 7px;
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      border: 1px solid #d2dcec;
    }

    td {
      padding: 9px 7px;
      color: #111;
      font-weight: 700;
      border: 1px solid #cfd8e6;
      background: #f8fbff;
      height: 36px;
    }

    tr:nth-child(even) td {
      background: #edf3fb;
    }

    .zona-cell {
      font-weight: 900;
      color: #092d91;
    }

    .num-cell {
      text-align: center;
      font-weight: 900;
    }

    .pct-cell {
      text-align: center;
      font-weight: 900;
    }

    .total-row td {
      background: #ff6f00 !important;
      color: #000;
      font-weight: 900;
      font-size: 15px;
    }

    .bottom-box {
      height: 105px;
      border: 2px solid #1b65e3;
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 7px 16px rgba(11, 45, 92, 0.10);
      display: grid;
      grid-template-columns: 110px 1fr 190px;
      align-items: center;
      padding: 12px 20px;
      overflow: hidden;
      position: relative;
    }

    .bottom-icon {
      width: 76px;
      height: 76px;
      border-radius: 16px;
      background: linear-gradient(135deg, #0d65df, #06349d);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      box-shadow: 0 8px 16px rgba(11, 45, 92, 0.22);
    }

    .bottom-divider {
      width: 2px;
      height: 72px;
      background: #1b65e3;
      margin-right: 20px;
    }

    .bottom-content {
      display: grid;
      grid-template-columns: 2px 1fr;
      gap: 20px;
      align-items: center;
    }

    .bottom-title {
      color: #092d91;
      font-size: 19px;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .bottom-text {
      font-size: 15px;
      color: #111;
      line-height: 1.25;
    }

    .watermark {
      opacity: 0.06;
      font-size: 100px;
      color: #0b3298;
      text-align: right;
      padding-right: 10px;
    }

    .axis-label {
      fill: #08245c;
      font-size: 15px;
      font-weight: 900;
    }

    .bar-value {
      fill: #08245c;
      font-size: 18px;
      font-weight: 900;
    }

    .legend-text {
      fill: #08245c;
      font-size: 16px;
      font-weight: 900;
    }

    .x-label {
      fill: #08245c;
      font-size: 18px;
      font-weight: 900;
    }

    .subtitle {
      fill: #092d91;
      font-size: 18px;
      font-weight: 900;
    }
  </style>
</head>

<body>
<%
  const safeTitulo = typeof titulo !== 'undefined'
    ? titulo
    : 'Yauricocha - Abril 2026 - Mina vs Superficie';

  const safeLogo = typeof logoText !== 'undefined'
    ? logoText
    : 'COMM';

  const rawItems = typeof items !== 'undefined' && Array.isArray(items)
    ? items
    : [];

  function num(v) {
    return Number(v) || 0;
  }

  function pct(v, t) {
    if (!t) return '0.00%';
    return ((num(v) / num(t)) * 100).toFixed(2) + '%';
  }

  function cortar(txt, n) {
    txt = String(txt || '');
    return txt.length > n ? txt.substring(0, n - 3) + '...' : txt;
  }

  let processedItems = rawItems.map(item => ({
    zona: item.zona || item.nombre || item.ubicacion || '',
    atenciones: num(item.atenciones || item.cantidad || item.total),
    horas: num(item.horas || item.tiempoHoras || item.tiempo)
  })).filter(item => item.zona);

  if (!processedItems.length) {
    const minaAt = typeof minaAtenciones !== 'undefined' ? num(minaAtenciones) : 72;
    const supAt = typeof superficieAtenciones !== 'undefined' ? num(superficieAtenciones) : 65;
    const minaHr = typeof minaHoras !== 'undefined' ? num(minaHoras) : 215;
    const supHr = typeof superficieHoras !== 'undefined' ? num(superficieHoras) : 176;

    processedItems = [
      { zona: 'Mina', atenciones: minaAt, horas: minaHr },
      { zona: 'Superficie', atenciones: supAt, horas: supHr }
    ];
  }

  const totalAt = num(
    typeof totalAtenciones !== 'undefined'
      ? totalAtenciones
      : processedItems.reduce((a, b) => a + b.atenciones, 0)
  );

  const totalHr = num(
    typeof totalHoras !== 'undefined'
      ? totalHoras
      : processedItems.reduce((a, b) => a + b.horas, 0)
  );

  processedItems = processedItems.map(item => ({
    ...item,
    pctAtenciones: item.pctAtenciones || pct(item.atenciones, totalAt),
    pctHoras: item.pctHoras || pct(item.horas, totalHr),
    horasPorAtencion: item.atenciones ? (item.horas / item.atenciones).toFixed(2) : '0.00'
  }));

  const mina = processedItems.find(i => String(i.zona).toLowerCase().includes('mina')) || processedItems[0] || {
    zona: 'Mina',
    atenciones: 0,
    horas: 0,
    pctAtenciones: '0.00%',
    pctHoras: '0.00%',
    horasPorAtencion: '0.00'
  };

  const superficie = processedItems.find(i => String(i.zona).toLowerCase().includes('super')) || processedItems[1] || {
    zona: 'Superficie',
    atenciones: 0,
    horas: 0,
    pctAtenciones: '0.00%',
    pctHoras: '0.00%',
    horasPorAtencion: '0.00'
  };

  const zonaPrincipal = mina.atenciones >= superficie.atenciones ? mina : superficie;
  const diferencia = Math.abs(mina.atenciones - superficie.atenciones);
  const maxAt = Math.max(...processedItems.map(i => i.atenciones), 1);
  const maxHr = Math.max(...processedItems.map(i => i.horas), 1);

  const chartLeft = 95;
  const chartTop = 70;
  const chartW = 700;
  const chartH = 330;
  const baseY = chartTop + chartH;
  const groupGap = chartW / processedItems.length;
  const barW = 72;

  const conclusion1 = `La mayor concentración de atenciones se presenta en ${zonaPrincipal.zona}.`;
  const conclusion2 = `La diferencia entre Mina y Superficie es de ${diferencia} atenciones durante el periodo.`;
%>

<div class="slide">
  <div class="corner"></div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= safeTitulo %></div>
    </div>

    <div class="logo">
      <div class="logo-symbol"></div>
      <div><%= safeLogo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▦</div>
      <div>
        <div class="kpi-label">Total Atenciones</div>
        <div class="kpi-value"><%= totalAt %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">◷</div>
      <div>
        <div class="kpi-label">Total Horas</div>
        <div class="kpi-value teal"><%= totalHr %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange">M</div>
      <div>
        <div class="kpi-label">Atenciones Mina</div>
        <div class="kpi-value orange"><%= mina.atenciones %></div>
        <div class="kpi-note"><%= mina.pctAtenciones %> del total</div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-purple">S</div>
      <div>
        <div class="kpi-label">Atenciones Superficie</div>
        <div class="kpi-value purple"><%= superficie.atenciones %></div>
        <div class="kpi-note"><%= superficie.pctAtenciones %> del total</div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">Δ</div>
      <div>
        <div class="kpi-label">Brecha Operativa</div>
        <div class="kpi-value teal"><%= diferencia %></div>
        <div class="kpi-note">Diferencia de atenciones</div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue">◎</div>
      <div>
        <div class="kpi-label">Zona Principal</div>
        <div class="kpi-value"><%= zonaPrincipal.atenciones %></div>
        <div class="kpi-note"><%= zonaPrincipal.zona %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <div class="panel">
      <div class="panel-title">
        <div class="circle">↗</div>
        Comparativo de Atenciones y Horas
      </div>

      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 850 460" preserveAspectRatio="none">

          <rect x="235" y="18" width="22" height="12" fill="#0b43bf"></rect>
          <text x="266" y="31" class="legend-text">Atenciones</text>

          <rect x="405" y="18" width="22" height="12" fill="#ff6f00"></rect>
          <text x="436" y="31" class="legend-text">Horas</text>

          <% [0, 0.25, 0.50, 0.75, 1].forEach(p => {
            const y = baseY - p * chartH;
            const valAt = Math.round(maxAt * p);
          %>
            <line x1="<%= chartLeft %>" y1="<%= y %>" x2="<%= chartLeft + chartW %>" y2="<%= y %>" stroke="#cfd8e6" stroke-width="1" stroke-dasharray="4 4"></line>
            <text x="60" y="<%= y + 5 %>" class="axis-label"><%= valAt %></text>
          <% }) %>

          <text x="24" y="230" transform="rotate(-90 24,230)" class="axis-label">ATENCIONES</text>

          <% processedItems.forEach((item, i) => {
            const xCenter = chartLeft + i * groupGap + groupGap / 2;
            const atH = maxAt ? (item.atenciones / maxAt) * chartH : 0;
            const hrH = maxHr ? (item.horas / maxHr) * chartH : 0;

            const atX = xCenter - barW - 8;
            const hrX = xCenter + 8;

            const atY = baseY - atH;
            const hrY = baseY - hrH;
          %>
            <rect x="<%= atX %>" y="<%= atY %>" width="<%= barW %>" height="<%= atH %>" fill="#0b43bf" rx="6"></rect>
            <rect x="<%= hrX %>" y="<%= hrY %>" width="<%= barW %>" height="<%= hrH %>" fill="#ff6f00" rx="6"></rect>

            <text x="<%= atX + barW / 2 %>" y="<%= atY - 10 %>" text-anchor="middle" class="bar-value"><%= item.atenciones %></text>
            <text x="<%= hrX + barW / 2 %>" y="<%= hrY - 10 %>" text-anchor="middle" class="bar-value"><%= item.horas %></text>

            <text x="<%= xCenter %>" y="430" text-anchor="middle" class="x-label"><%= item.zona %></text>
          <% }) %>

          <line x1="<%= chartLeft %>" y1="<%= baseY %>" x2="<%= chartLeft + chartW %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>
          <line x1="<%= chartLeft %>" y1="<%= chartTop %>" x2="<%= chartLeft %>" y2="<%= baseY %>" stroke="#a9bad3" stroke-width="2"></line>
        </svg>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">
        <div class="circle">▤</div>
        Resumen Mina / Superficie
      </div>

      <div class="right-content">
        <div class="mini-cards">
          <div class="mini-card">
            <div class="mini-title">Mina</div>
            <div class="mini-value"><%= mina.atenciones %></div>
            <div class="mini-detail">
              <%= mina.horas %> horas<br>
              <%= mina.horasPorAtencion %> h/atención
            </div>
          </div>

          <div class="mini-card">
            <div class="mini-title">Superficie</div>
            <div class="mini-value orange"><%= superficie.atenciones %></div>
            <div class="mini-detail">
              <%= superficie.horas %> horas<br>
              <%= superficie.horasPorAtencion %> h/atención
            </div>
          </div>
        </div>

        <table>
          <thead>
            <tr>
              <th>Zona</th>
              <th>Atenciones</th>
              <th>% Aten.</th>
              <th>Horas</th>
              <th>% Horas</th>
            </tr>
          </thead>

          <tbody>
            <% processedItems.forEach(item => { %>
              <tr>
                <td class="zona-cell"><%= item.zona %></td>
                <td class="num-cell"><%= item.atenciones %></td>
                <td class="pct-cell"><%= item.pctAtenciones %></td>
                <td class="num-cell"><%= item.horas %></td>
                <td class="pct-cell"><%= item.pctHoras %></td>
              </tr>
            <% }) %>

            <tr class="total-row">
              <td>TOTAL</td>
              <td class="num-cell"><%= totalAt %></td>
              <td class="pct-cell">100.00%</td>
              <td class="num-cell"><%= totalHr %></td>
              <td class="pct-cell">100.00%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="bottom-box">
    <div class="bottom-icon">◎</div>

    <div class="bottom-content">
      <div class="bottom-divider"></div>

      <div>
        <div class="bottom-title">Distribución operativa por zona</div>
        <div class="bottom-text">
          <%= conclusion1 %><br>
          <%= conclusion2 %>
        </div>
      </div>
    </div>

    <div class="watermark">↗</div>
  </div>
</div>
</body>
</html>
