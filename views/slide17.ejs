<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 17 - Top Suministros General</title>

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; }
    body { background: #eef4fb; }

    .slide {
      width: 1600px;
      height: 900px;
      background: linear-gradient(180deg, #ffffff 0%, #f4f8ff 100%);
      color: #08245c;
      overflow: hidden;
      position: relative;
      padding: 22px 26px 0 26px;
    }

    .bottom-band {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 100%;
      height: 25px;
      background: linear-gradient(90deg, #082d91 0%, #0d65df 55%, #13b7ba 100%);
      z-index: 0;
    }

    .logo-curve {
      position: absolute;
      top: -78px;
      right: -70px;
      width: 430px;
      height: 165px;
      background: #123f9d;
      border-bottom-left-radius: 220px;
      z-index: 1;
    }

    .logo-text {
      position: absolute;
      top: 27px;
      right: 58px;
      color: white;
      font-size: 38px;
      font-weight: 900;
      z-index: 2;
      letter-spacing: 1px;
    }

    .header {
      position: relative;
      z-index: 3;
      height: 86px;
      display: flex;
      align-items: flex-start;
      margin-bottom: 10px;
      padding-right: 360px;
    }

    .title-wrap { display: flex; align-items: flex-start; gap: 18px; }

    .title-bar {
      width: 13px;
      height: 64px;
      border-radius: 6px;
      background: linear-gradient(180deg, #0d65df, #13b7ba);
      margin-top: 4px;
    }

    .title {
      font-size: 41px;
      line-height: 1.05;
      font-weight: 900;
      color: #071f5c;
      letter-spacing: -0.8px;
      text-transform: uppercase;
    }

    .kpi-row {
      position: relative;
      z-index: 3;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 16px;
      margin-bottom: 14px;
    }

    .kpi-card {
      height: 112px;
      background: #ffffff;
      border: 1px solid #d2dceb;
      border-radius: 15px;
      box-shadow: 0 7px 16px rgba(11,45,92,0.15);
      display: grid;
      grid-template-columns: 76px 1fr;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      overflow: hidden;
    }

    .kpi-icon {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      font-weight: 900;
      box-shadow: 0 9px 15px rgba(0,0,0,0.17);
    }

    .bg-blue { background: linear-gradient(135deg, #1264df, #06339b); }
    .bg-teal { background: linear-gradient(135deg, #1ac4c6, #087a87); }
    .bg-orange { background: linear-gradient(135deg, #ffb51d, #ff5f00); }
    .bg-purple { background: linear-gradient(135deg, #9542e8, #5520aa); }

    .kpi-label {
      font-size: 13px;
      font-weight: 900;
      color: #092869;
      line-height: 1.08;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 34px;
      font-weight: 900;
      line-height: 1;
      color: #0d55d8;
    }

    .kpi-sub {
      font-size: 9.8px;
      font-weight: 900;
      color: #222;
      margin-top: 4px;
      line-height: 1.08;
      white-space: normal;
      word-break: normal;
    }

    .teal { color: #0a8a96; }
    .orange { color: #ff6200; }
    .purple { color: #7a35d7; }

    .main-grid {
      position: relative;
      z-index: 3;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 18px;
      height: 465px;
      margin-bottom: 10px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #cddbef;
      border-radius: 16px;
      box-shadow: 0 7px 16px rgba(11,45,92,0.13);
      overflow: hidden;
    }

    .panel-title {
      height: 43px;
      background: linear-gradient(90deg, #0b3298 0%, #0d5dd4 50%, #11b7bb 100%);
      color: white;
      display: flex;
      align-items: center;
      padding-left: 74px;
      font-size: 24px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.2px;
      position: relative;
    }

    .panel-icon {
      position: absolute;
      left: 18px;
      top: -16px;
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: #0b3298;
      border: 5px solid #e8eefb;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 31px;
      font-weight: 900;
      box-shadow: 0 5px 12px rgba(0,0,0,0.18);
    }

    .chart-box { height: 422px; padding: 12px 20px 6px 20px; }
    .table-box { height: 422px; padding: 12px 16px 8px 16px; }

    table { width: 100%; border-collapse: collapse; table-layout: fixed; }

    th {
      background: #0d3298;
      color: white;
      padding: 8px 6px;
      text-transform: uppercase;
      font-size: 12px;
      border: 1px solid #c7d4e8;
    }

    td {
      padding: 6px 6px;
      border: 1px solid #c7d4e8;
      color: #111;
      font-size: 11.6px;
      font-weight: 700;
      vertical-align: middle;
    }

    tr:nth-child(even) td { background: #eaf1fa; }
    tr:nth-child(odd) td { background: #f7fbff; }

    .rank {
      background: #0d3298 !important;
      color: white;
      text-align: center;
      font-weight: 900;
      width: 34px;
    }

    .name-cell {
      font-size: 10.4px;
      line-height: 1.12;
      white-space: normal;
      word-break: normal;
      overflow-wrap: break-word;
    }

    .center { text-align: center; }

    .total-row td {
      background: #ff6900 !important;
      color: #000;
      font-weight: 900;
    }

    .bottom-box {
      position: relative;
      z-index: 3;
      height: 120px;
      background: #ffffff;
      border: 2px solid #0d65df;
      border-radius: 16px;
      box-shadow: 0 7px 16px rgba(11,45,92,0.10);
      display: grid;
      grid-template-columns: 100px 1fr 130px;
      align-items: center;
      padding: 12px 20px;
      overflow: hidden;
    }

    .bottom-icon {
      width: 74px;
      height: 74px;
      border-radius: 16px;
      background: linear-gradient(135deg, #0d65df, #13b7ba);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 38px;
      font-weight: 900;
      box-shadow: 0 8px 15px rgba(11,45,92,0.20);
    }

    .bottom-text-wrap {
      border-left: 2px solid #0d65df;
      padding-left: 22px;
      padding-right: 20px;
    }

    .bottom-title {
      font-size: 19px;
      font-weight: 900;
      color: #092d91;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .bottom-text {
      font-size: 15px;
      color: #111;
      line-height: 1.25;
      max-width: 1050px;
    }

    .bottom-text p { margin-bottom: 3px; }

    .watermark {
      font-size: 78px;
      color: #eef3fb;
      font-weight: 900;
      text-align: right;
      padding-right: 4px;
    }

    .axis-label { fill: #08245c; font-size: 13px; font-weight: 900; }
    .axis-title { fill: #08245c; font-size: 15px; font-weight: 900; }
    .bar-label { fill: #08245c; font-size: 13px; font-weight: 900; }
    .line-label { fill: #08245c; font-size: 12px; font-weight: 900; }
    .x-label { fill: #08245c; font-size: 8.6px; font-weight: 800; }
    .legend-text { fill: #08245c; font-size: 14px; font-weight: 900; }
  </style>
</head>

<body>
<%
  const safeTitulo = typeof titulo !== 'undefined'
    ? titulo
    : 'Yauricocha - Marzo 2026 - Top Suministros General';

  const rawItems = typeof items !== 'undefined' && Array.isArray(items)
    ? items
    : [];

  function num(v) {
    return Number(v) || 0;
  }

  function pct(v, t) {
    if (!t) return '0.00%';
    return ((num(v) / num(t)) * 100).toFixed(2) + '%';
  }

  function dividirTextoSvg(txt, maxCaracteres) {
    txt = String(txt || '').trim();
    if (!txt) return [''];

    const palabras = txt.split(/\s+/);
    const lineas = [];
    let actual = '';

    palabras.forEach(palabra => {
      const prueba = actual ? actual + ' ' + palabra : palabra;

      if (prueba.length <= maxCaracteres) {
        actual = prueba;
      } else {
        if (actual) lineas.push(actual);
        actual = palabra;
      }
    });

    if (actual) lineas.push(actual);
    return lineas;
  }

  const totalSum = num(
    typeof totalSuministrosGeneral !== 'undefined'
      ? totalSuministrosGeneral
      : typeof totalSuministros !== 'undefined'
        ? totalSuministros
        : rawItems.reduce((a, b) => a + num(b.cantidad), 0)
  );

  const processedItems = rawItems.slice(0, 10).map(item => ({
    nombre: item.nombre || item.descripcion || item.insumo || item.suministro || '',
    cantidad: num(item.cantidad),
    porcentaje: item.porcentaje || pct(item.cantidad, totalSum)
  }));

  let acumulado = 0;

  processedItems.forEach(item => {
    acumulado += item.cantidad;
    item.pctAcumulado = totalSum ? (acumulado / totalSum) * 100 : 0;
  });

  const top1 = processedItems[0] || {
    nombre: '-',
    cantidad: 0,
    porcentaje: '0.00%',
    pctAcumulado: 0
  };

  const top2Cantidad = processedItems.slice(0, 2).reduce((a, b) => a + b.cantidad, 0);
  const top3Cantidad = processedItems.slice(0, 3).reduce((a, b) => a + b.cantidad, 0);

  const pctTop2Valor = typeof porcentajeTop2 !== 'undefined'
    ? porcentajeTop2
    : pct(top2Cantidad, totalSum);

  const pctTop3Valor = typeof porcentajeTop3 !== 'undefined'
    ? porcentajeTop3
    : pct(top3Cantidad, totalSum);

  const maxCantRaw = Math.max(...processedItems.map(i => i.cantidad), 1);
  const maxCant = Math.ceil(maxCantRaw / 10) * 10;

  const chartLeft = 88;
  const chartTop = 46;
  const chartW = 670;
  const chartH = 245;
  const baseY = chartTop + chartH;
  const gap = processedItems.length ? chartW / processedItems.length : chartW;
  const barW = Math.min(42, gap * 0.42);

  const conclusion1 =
    typeof insight !== 'undefined' && insight
      ? insight
      : `El suministro de mayor uso general corresponde a ${top1.nombre}.`;

  const conclusion2 =
    `El Top 3 representa ${pctTop3Valor} del total general de suministros utilizados.`;
%>

<div class="slide">
  <div class="bottom-band"></div>
  <div class="logo-curve"></div>
  <div class="logo-text">COMM</div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= safeTitulo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue">▦</div>
      <div>
        <div class="kpi-label">Total Suministros</div>
        <div class="kpi-value"><%= totalSum %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">#</div>
      <div>
        <div class="kpi-label">Cantidad de Ítems</div>
        <div class="kpi-value teal"><%= processedItems.length %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange">▥</div>
      <div>
        <div class="kpi-label">Principal Suministro</div>
        <div class="kpi-value orange"><%= top1.cantidad %></div>
        <div class="kpi-sub"><%= top1.nombre %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-purple">%</div>
      <div>
        <div class="kpi-label">% Principal</div>
        <div class="kpi-value purple"><%= top1.porcentaje %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal">2</div>
      <div>
        <div class="kpi-label">Top 2 Participación</div>
        <div class="kpi-value teal"><%= pctTop2Valor %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue">3</div>
      <div>
        <div class="kpi-label">Top 3 Participación</div>
        <div class="kpi-value"><%= pctTop3Valor %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <div class="panel">
      <div class="panel-title">
        <div class="panel-icon">↗</div>
        Pareto de Suministros General
      </div>

      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 820 380" preserveAspectRatio="none">
          <% [0, 0.25, 0.50, 0.75, 1].forEach(p => {
            const y = baseY - p * chartH;
            const val = Math.round(maxCant * p);
          %>
            <line x1="<%= chartLeft %>" y1="<%= y %>" x2="<%= chartLeft + chartW %>" y2="<%= y %>"
              stroke="#d6dde8" stroke-width="1" stroke-dasharray="4 4"></line>
            <text x="45" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <text x="20" y="175" transform="rotate(-90 20,175)" class="axis-title">CANTIDAD</text>

          <text x="190" y="24" class="legend-text">Cantidad (Suministros)</text>
          <rect x="158" y="12" width="24" height="14" fill="#1248bf"></rect>

          <line x1="470" y1="19" x2="520" y2="19" stroke="#ff6200" stroke-width="4"></line>
          <circle cx="495" cy="19" r="6" fill="#ff6200"></circle>
          <text x="535" y="24" class="legend-text">% Acumulado</text>

          <% let linePoints = []; %>

          <% processedItems.forEach((item, i) => {
            const xCenter = chartLeft + i * gap + gap / 2;
            const barH = maxCant ? (item.cantidad / maxCant) * chartH : 0;
            const y = baseY - barH;
            const x = xCenter - barW / 2;
            const pctY = baseY - (item.pctAcumulado / 100) * chartH;
            linePoints.push(`${xCenter},${pctY}`);
            const lineasNombre = dividirTextoSvg(item.nombre, 14);
          %>
            <rect x="<%= x %>" y="<%= y %>" width="<%= barW %>" height="<%= barH %>" rx="3" fill="#1248bf"></rect>

            <text x="<%= xCenter %>" y="<%= y - 8 %>" text-anchor="middle" class="bar-label">
              <%= item.cantidad %>
            </text>

            <text x="<%= xCenter %>" y="314" text-anchor="middle" class="x-label">
              <% lineasNombre.forEach((linea, idx) => { %>
                <tspan x="<%= xCenter %>" dy="<%= idx === 0 ? 0 : 10 %>"><%= linea %></tspan>
              <% }) %>
            </text>
          <% }) %>

          <% if (linePoints.length) { %>
            <polyline points="<%= linePoints.join(' ') %>" fill="none" stroke="#ff6200" stroke-width="4"></polyline>

            <% processedItems.forEach((item, i) => {
              const xCenter = chartLeft + i * gap + gap / 2;
              const pctY = baseY - (item.pctAcumulado / 100) * chartH;
            %>
              <circle cx="<%= xCenter %>" cy="<%= pctY %>" r="6" fill="#ff6200"></circle>
              <text x="<%= xCenter %>" y="<%= pctY - 12 %>" text-anchor="middle" class="line-label">
                <%= item.pctAcumulado.toFixed(2) %>%
              </text>
            <% }) %>
          <% } %>

          <text x="775" y="<%= chartTop + 4 %>" class="axis-label">100%</text>
          <text x="780" y="<%= chartTop + chartH * 0.2 %>" class="axis-label">80%</text>
          <text x="780" y="<%= chartTop + chartH * 0.4 %>" class="axis-label">60%</text>
          <text x="780" y="<%= chartTop + chartH * 0.6 %>" class="axis-label">40%</text>
          <text x="780" y="<%= chartTop + chartH * 0.8 %>" class="axis-label">20%</text>
          <text x="780" y="<%= baseY + 4 %>" class="axis-label">0%</text>

          <line x1="<%= chartLeft %>" y1="<%= baseY %>" x2="<%= chartLeft + chartW %>" y2="<%= baseY %>"
            stroke="#c5cfdf" stroke-width="2"></line>
        </svg>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">
        <div class="panel-icon">▤</div>
        Detalle Top 10 Suministros
      </div>

      <div class="table-box">
        <table>
          <thead>
            <tr>
              <th style="width: 40px;">#</th>
              <th>Suministro</th>
              <th style="width: 105px;">Cantidad</th>
              <th style="width: 90px;">%</th>
            </tr>
          </thead>

          <tbody>
            <% processedItems.forEach((item, i) => { %>
              <tr>
                <td class="rank"><%= i + 1 %></td>
                <td class="name-cell"><%= item.nombre %></td>
                <td class="center"><%= item.cantidad %></td>
                <td class="center"><%= item.porcentaje %></td>
              </tr>
            <% }) %>

            <tr class="total-row">
              <td colspan="2">TOTAL GENERAL</td>
              <td class="center"><%= totalSum %></td>
              <td class="center">100.00%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="bottom-box">
    <div class="bottom-icon">▦</div>

    <div class="bottom-text-wrap">
      <div class="bottom-title">Suministros usados en general</div>
      <div class="bottom-text">
        <p><%= conclusion1 %></p>
        <p><%= conclusion2 %></p>
      </div>
    </div>

    <div class="watermark">↗</div>
  </div>
</div>
</body>
</html>
