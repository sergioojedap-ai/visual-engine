<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title><%= titulo %></title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #eef4fb;
    }

    .slide {
      width: 1600px;
      height: 900px;
      margin: 0 auto;
      background: linear-gradient(180deg, #f7fbff 0%, #eef5fb 100%);
      color: #0b2e6d;
      overflow: hidden;
      position: relative;
      padding: 16px 18px 14px 18px;
    }

    /* HEADER */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 10px;
      position: relative;
    }

    .title-wrap {
      display: flex;
      align-items: center;
      gap: 14px;
      padding-top: 2px;
    }

    .title-accent {
      width: 10px;
      height: 60px;
      border-radius: 8px;
      background: linear-gradient(180deg, #1d66db 0%, #0b49bf 100%);
      box-shadow: 0 2px 6px rgba(11, 73, 191, 0.25);
    }

    .title {
      font-size: 34px;
      font-weight: 900;
      color: #0b2e6d;
      letter-spacing: 0.2px;
      line-height: 1.05;
      text-transform: uppercase;
    }

    .logo-box {
      min-width: 260px;
      height: 82px;
      background: linear-gradient(90deg, #0c42b7 0%, #0e5bde 55%, #0836a2 100%);
      border-bottom-left-radius: 46px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0 28px;
      color: white;
      font-size: 34px;
      font-weight: 900;
      gap: 14px;
      box-shadow: 0 8px 18px rgba(15, 78, 180, 0.18);
      margin-top: -16px;
      margin-right: -18px;
    }

    .logo-icon {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #79d6ff, #1596d8 60%, #0b5ca8 100%);
      border: 2px solid rgba(255,255,255,0.55);
      flex-shrink: 0;
    }

    .top-line {
      width: 100%;
      height: 2px;
      background: #c7d7ee;
      margin-bottom: 16px;
      margin-top: 2px;
    }

    /* KPI CARDS */
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 12px;
      margin-bottom: 14px;
    }

    .kpi-card {
      background: #ffffff;
      border: 1px solid #d7e4f2;
      border-radius: 18px;
      min-height: 112px;
      display: flex;
      align-items: center;
      padding: 12px 14px;
      box-shadow: 0 6px 16px rgba(16, 63, 125, 0.08);
      position: relative;
      overflow: hidden;
    }

    .kpi-card::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 5px;
      opacity: 0.95;
    }

    .kpi-blue::after { background: linear-gradient(90deg, #1b67db, #1b67db); }
    .kpi-teal::after { background: linear-gradient(90deg, #16a8b6, #16a8b6); }
    .kpi-orange::after { background: linear-gradient(90deg, #ff8800, #ff8800); }
    .kpi-purple::after { background: linear-gradient(90deg, #7d3fe4, #7d3fe4); }
    .kpi-cyan::after { background: linear-gradient(90deg, #17b0b8, #17b0b8); }

    .kpi-icon {
      width: 62px;
      height: 62px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      color: #fff;
      font-weight: 700;
      flex-shrink: 0;
      box-shadow: inset 0 -8px 18px rgba(0,0,0,0.08);
    }

    .bg-blue { background: linear-gradient(135deg, #1e6adf, #0f4ec8); }
    .bg-teal { background: linear-gradient(135deg, #21c2c9, #1496a5); }
    .bg-orange { background: linear-gradient(135deg, #ffb01f, #ff8a00); }
    .bg-purple { background: linear-gradient(135deg, #9446f4, #6f35dc); }

    .kpi-content {
      padding-left: 14px;
      flex: 1;
      min-width: 0;
    }

    .kpi-label {
      font-size: 14px;
      font-weight: 800;
      color: #172f6e;
      line-height: 1.15;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 26px;
      font-weight: 900;
      line-height: 1.05;
      color: #1437a2;
      word-break: break-word;
    }

    .kpi-value.orange { color: #ff7a00; }
    .kpi-value.teal { color: #1198a6; }
    .kpi-value.purple { color: #7b42e2; }

    /* MAIN GRID */
    .middle-row {
      display: grid;
      grid-template-columns: 1.34fr 1fr;
      gap: 14px;
      margin-bottom: 14px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #d7e4f2;
      border-radius: 22px;
      box-shadow: 0 8px 18px rgba(18, 67, 133, 0.08);
      overflow: hidden;
    }

    .panel-header {
      height: 38px;
      display: flex;
      align-items: center;
      padding: 0 18px;
      color: #fff;
      font-weight: 900;
      font-size: 16px;
      text-transform: uppercase;
      background: linear-gradient(90deg, #113b99 0%, #1764d9 35%, #1ac2c4 100%);
      letter-spacing: 0.2px;
    }

    .panel-body {
      padding: 14px 18px 14px 18px;
    }

    /* GRAPH PANEL */
    .graph-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 2px;
    }

    .graph-item {
      display: grid;
      grid-template-columns: 34px 1fr 380px 58px 76px;
      align-items: center;
      gap: 10px;
      min-height: 30px;
    }

    .rank {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      background: #eef4fb;
      color: #1d4ac2;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 900;
      border: 1px solid #dbe6f5;
    }

    .item-name {
      font-size: 13px;
      font-weight: 700;
      color: #1b2f67;
      line-height: 1.12;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .bar-track {
      width: 100%;
      height: 20px;
      background: #e8eef6;
      border-radius: 999px;
      position: relative;
      overflow: hidden;
      border: 1px solid #d7e1ef;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #124dd0 0%, #1874e0 45%, #1cc4c6 100%);
      min-width: 16px;
      position: relative;
    }

    .value-label {
      text-align: right;
      font-size: 13px;
      font-weight: 900;
      color: #1f3ca8;
    }

    .pct-label {
      text-align: right;
      font-size: 13px;
      font-weight: 900;
      color: #ff7a00;
    }

    /* TABLE PANEL */
    .table-wrap {
      width: 100%;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 4px;
      table-layout: fixed;
      font-size: 13px;
    }

    thead th {
      background: #173d9a;
      color: #fff;
      padding: 9px 10px;
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
      border: none;
    }

    thead th:first-child {
      border-top-left-radius: 10px;
      border-bottom-left-radius: 10px;
      width: 42px;
      text-align: center;
    }

    thead th:nth-child(2) {
      text-align: left;
      width: auto;
    }

    thead th:nth-child(3) {
      width: 78px;
      text-align: center;
    }

    thead th:nth-child(4) {
      width: 82px;
      text-align: center;
      border-top-right-radius: 10px;
      border-bottom-right-radius: 10px;
    }

    tbody td {
      background: #f4f8fc;
      padding: 7px 10px;
      color: #23376d;
      border-top: 1px solid #e0e8f3;
      border-bottom: 1px solid #e0e8f3;
    }

    tbody tr:nth-child(even) td {
      background: #edf4fb;
    }

    tbody td:first-child {
      text-align: center;
      font-weight: 800;
      color: #1d3ea7;
      border-left: 1px solid #e0e8f3;
    }

    tbody td:nth-child(2) {
      font-weight: 700;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    tbody td:nth-child(3) {
      text-align: center;
      font-weight: 800;
      color: #173a95;
    }

    tbody td:nth-child(4) {
      text-align: center;
      font-weight: 800;
      color: #ff7a00;
      border-right: 1px solid #e0e8f3;
    }

    /* BOTTOM */
    .bottom-row {
      display: grid;
      grid-template-columns: 1.05fr 0.75fr 1.1fr;
      gap: 14px;
      align-items: stretch;
    }

    .mini-box {
      background: #ffffff;
      border: 1px solid #d7e4f2;
      border-radius: 18px;
      box-shadow: 0 8px 18px rgba(18, 67, 133, 0.08);
      min-height: 140px;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
      overflow: hidden;
    }

    .mini-icon {
      width: 74px;
      height: 74px;
      border-radius: 18px;
      background: linear-gradient(135deg, #1b67db 0%, #18c0c5 100%);
      color: white;
      font-size: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: inset 0 -10px 18px rgba(0,0,0,0.08);
    }

    .mini-title {
      font-size: 17px;
      font-weight: 900;
      color: #1d3a97;
      margin-bottom: 8px;
    }

    .mini-text {
      font-size: 13px;
      line-height: 1.45;
      color: #28406f;
    }

    .mini-data {
      width: 100%;
    }

    .mini-data-title {
      font-size: 17px;
      font-weight: 900;
      color: #1d3a97;
      margin-bottom: 10px;
    }

    .data-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 16px;
      font-size: 14px;
      color: #1d2e5a;
    }

    .data-grid .value {
      font-weight: 900;
      color: #1437a2;
      text-align: right;
    }

    .insight-box {
      min-height: 140px;
      border-radius: 18px;
      padding: 14px 18px;
      background: linear-gradient(90deg, #0f3ca8 0%, #0f5ed8 35%, #13bec5 100%);
      color: white;
      box-shadow: 0 10px 22px rgba(17, 83, 176, 0.18);
      overflow: hidden;
    }

    .insight-title {
      font-size: 18px;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .insight-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .insight-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      align-items: start;
      font-size: 13px;
      line-height: 1.35;
      padding-bottom: 8px;
      border-bottom: 1px dashed rgba(255,255,255,0.28);
    }

    .insight-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .insight-bullet {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,0.95);
      color: #1b4fc7;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 13px;
      margin-top: 1px;
    }
  </style>
</head>
<body>
  <div class="slide">
    <div class="header">
      <div class="title-wrap">
        <div class="title-accent"></div>
        <div class="title"><%= titulo %></div>
      </div>

      <div class="logo-box">
        <div class="logo-icon"></div>
        <div><%= logoText || 'COMM' %></div>
      </div>
    </div>

    <div class="top-line"></div>

    <div class="kpi-row">
      <div class="kpi-card kpi-blue">
        <div class="kpi-icon bg-blue">▣</div>
        <div class="kpi-content">
          <div class="kpi-label">Total Requerimientos</div>
          <div class="kpi-value"><%= totalRequerimientos %></div>
        </div>
      </div>

      <div class="kpi-card kpi-teal">
        <div class="kpi-icon bg-teal">#</div>
        <div class="kpi-content">
          <div class="kpi-label">Categorías Top</div>
          <div class="kpi-value teal"><%= items.length %></div>
        </div>
      </div>

      <div class="kpi-card kpi-orange">
        <div class="kpi-icon bg-orange">★</div>
        <div class="kpi-content">
          <div class="kpi-label">Principal Requerimiento</div>
          <div class="kpi-value" style="font-size:14px; line-height:1.18; color:#173a95;">
            <%= principalRequerimiento %>
          </div>
        </div>
      </div>

      <div class="kpi-card kpi-purple">
        <div class="kpi-icon bg-purple">●</div>
        <div class="kpi-content">
          <div class="kpi-label">Cantidad Principal</div>
          <div class="kpi-value purple"><%= cantidadPrincipal %></div>
        </div>
      </div>

      <div class="kpi-card kpi-blue">
        <div class="kpi-icon bg-blue">%</div>
        <div class="kpi-content">
          <div class="kpi-label">Participación Top 3</div>
          <div class="kpi-value"><%= pctTop3 %></div>
        </div>
      </div>

      <div class="kpi-card kpi-teal">
        <div class="kpi-icon bg-teal">▦</div>
        <div class="kpi-content">
          <div class="kpi-label">Cobertura Top 10</div>
          <div class="kpi-value teal"><%= pctTop10 %></div>
        </div>
      </div>
    </div>

    <div class="middle-row">
      <div class="panel">
        <div class="panel-header">Gráfico Top 10 Requerimientos</div>
        <div class="panel-body">
          <div class="graph-list">
            <% 
              const maxCant = Math.max(...items.map(i => Number(i.cantidad) || 0), 1);
              items.forEach((item, index) => {
                const cant = Number(item.cantidad) || 0;
                const barWidth = (cant / maxCant) * 100;
            %>
              <div class="graph-item">
                <div class="rank"><%= index + 1 %></div>
                <div class="item-name" title="<%= item.nombre %>"><%= item.nombre %></div>
                <div class="bar-track">
                  <div class="bar-fill" style="width:<%= barWidth %>%"></div>
                </div>
                <div class="value-label"><%= item.cantidad %></div>
                <div class="pct-label"><%= item.porcentaje %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">Tabla Top 10 Requerimientos</div>
        <div class="panel-body">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Requerimiento</th>
                  <th>Cant.</th>
                  <th>%</th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach((item, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td title="<%= item.nombre %>"><%= item.nombre %></td>
                    <td><%= item.cantidad %></td>
                    <td><%= item.porcentaje %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="bottom-row">
      <div class="mini-box">
        <div class="mini-icon">↗</div>
        <div>
          <div class="mini-title">Concentración de Requerimientos</div>
          <div class="mini-text">
            El análisis del Top 10 permite identificar las solicitudes más recurrentes y priorizar
            acciones de mejora operativa.
          </div>
        </div>
      </div>

      <div class="mini-box">
        <div class="mini-icon">▤</div>
        <div class="mini-data">
          <div class="mini-data-title">Datos del Top 10</div>
          <div class="data-grid">
            <div>TOTAL:</div>
            <div class="value"><%= totalRequerimientos %></div>

            <div>TOP 10:</div>
            <div class="value"><%= totalTop10 %></div>

            <div>COBERTURA:</div>
            <div class="value"><%= pctTop10 %></div>
          </div>
        </div>
      </div>

      <div class="insight-box">
        <div class="insight-title">Insights Ejecutivos</div>
        <div class="insight-list">
          <% (insights || [insight]).slice(0,3).forEach((txt, i) => { %>
            <div class="insight-item">
              <div class="insight-bullet"><%= i + 1 %></div>
              <div><%= txt %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
