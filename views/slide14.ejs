<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 14 - Top 10 Requerimientos</title>
  <link rel="stylesheet" href="/public/styles.css" />

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #ffffff;
    }

    .canvas {
      width: 1600px;
      height: 900px;
      padding: 18px 26px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
      position: relative;
      overflow: hidden;
    }

    .corner-ribbon {
      position: absolute;
      right: 0;
      top: 0;
      width: 325px;
      height: 80px;
      background: linear-gradient(135deg, #06328f, #0b63df);
      border-bottom-left-radius: 120px;
      z-index: 0;
    }

    .slide-title-row {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .title-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .title-accent {
      width: 12px;
      height: 52px;
      background: #145fe0;
      border-radius: 4px;
    }

    .main-title {
      font-size: 37px;
      font-weight: 900;
      color: #062a63;
      letter-spacing: 0.2px;
      margin: 0;
      text-transform: uppercase;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 14px;
      color: white;
      font-size: 36px;
      font-weight: 900;
      z-index: 3;
      padding-right: 22px;
    }

    .logo-dot {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #55d9ff, #0b4fc7);
      border: 3px solid rgba(255,255,255,0.75);
    }

    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 16px;
      margin-bottom: 16px;
    }

    .kpi {
      height: 105px;
      background: #ffffff;
      border: 1px solid #d6e2f2;
      border-radius: 14px;
      box-shadow: 0 6px 14px rgba(10, 45, 91, 0.13);
      padding: 15px 15px;
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 14px;
      align-items: center;
    }

    .kpi-icon {
      width: 66px;
      height: 66px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 31px;
      font-weight: 900;
    }

    .blue { background: linear-gradient(135deg, #0b5ed7, #0640a5); }
    .teal { background: linear-gradient(135deg, #08b9bd, #07878f); }
    .orange { background: linear-gradient(135deg, #ffb000, #ff6200); }
    .purple { background: linear-gradient(135deg, #8d48e8, #6125c9); }

    .kpi-label {
      font-size: 13px;
      line-height: 1.15;
      color: #08275c;
      font-weight: 900;
      text-transform: uppercase;
      min-height: 30px;
    }

    .kpi-value {
      font-size: 35px;
      font-weight: 900;
      line-height: 1;
      margin-top: 4px;
      white-space: nowrap;
    }

    .kpi-small-value {
      font-size: 21px;
      font-weight: 900;
      line-height: 1.05;
      margin-top: 4px;
      color: #0b3298;
    }

    .value-blue { color: #145fe0; }
    .value-teal { color: #07939b; }
    .value-orange { color: #ff6200; }
    .value-purple { color: #6f35d8; }

    .main-content {
      display: grid;
      grid-template-columns: 1.12fr 0.88fr;
      gap: 22px;
      height: 480px;
      margin-bottom: 18px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #d6e2f2;
      border-radius: 16px;
      box-shadow: 0 7px 18px rgba(10, 45, 91, 0.13);
      overflow: hidden;
    }

    .panel-title {
      height: 42px;
      background: linear-gradient(90deg, #0b3298 0%, #0b5ed7 55%, #12b8c8 100%);
      color: white;
      font-size: 19px;
      font-weight: 900;
      display: flex;
      align-items: center;
      padding: 0 24px;
      text-transform: uppercase;
    }

    .chart-area {
      height: 438px;
      padding: 20px 24px 18px 24px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 38px 245px 1fr 62px;
      align-items: center;
      gap: 12px;
      height: 39px;
      margin-bottom: 2px;
    }

    .rank {
      width: 29px;
      height: 29px;
      border-radius: 8px;
      background: #eef5ff;
      color: #0b3298;
      font-size: 14px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .name {
      font-size: 13.5px;
      color: #08275c;
      font-weight: 800;
      line-height: 1.15;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .bar-track {
      height: 22px;
      background: #edf4ff;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid #d6e2f2;
    }

    .bar-fill {
      height: 100%;
      border-radius: 20px;
      background: linear-gradient(90deg, #073fb4 0%, #0b63df 70%, #12b8c8 100%);
    }

    .qty {
      font-size: 16px;
      color: #0b3298;
      font-weight: 900;
      text-align: right;
    }

    .table-area {
      height: 438px;
      padding: 18px 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      overflow: hidden;
      border-radius: 12px;
    }

    th {
      background: #0b3298;
      color: white;
      padding: 10px 8px;
      text-transform: uppercase;
      font-size: 12px;
      letter-spacing: 0.2px;
    }

    td {
      padding: 8.5px 8px;
      border-bottom: 1px solid #e3edf8;
      color: #08275c;
      font-weight: 700;
      vertical-align: middle;
    }

    tr:nth-child(even) td {
      background: #f4f8ff;
    }

    .td-rank {
      text-align: center;
      color: #0b3298;
      font-weight: 900;
      width: 42px;
    }

    .td-name {
      max-width: 280px;
      line-height: 1.15;
    }

    .td-num {
      text-align: center;
      font-weight: 900;
      color: #0b3298;
      width: 80px;
    }

    .td-pct {
      text-align: center;
      font-weight: 900;
      color: #ff6200;
      width: 80px;
    }

    .bottom-row {
      display: grid;
      grid-template-columns: 1fr 0.72fr 1.05fr;
      gap: 20px;
      height: 145px;
    }

    .bottom-card {
      background: #ffffff;
      border: 1px solid #0b5ed7;
      border-radius: 14px;
      box-shadow: 0 5px 13px rgba(10, 45, 91, 0.10);
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 18px;
      overflow: hidden;
    }

    .bottom-card.teal-border {
      border-color: #13aeb5;
    }

    .bottom-card.dark {
      background: linear-gradient(120deg, #06328f 0%, #0c62d9 55%, #12b8c8 100%);
      border-color: transparent;
      color: white;
      display: block;
      padding: 16px 26px;
    }

    .big-icon {
      width: 80px;
      height: 80px;
      border-radius: 17px;
      color: white;
      font-size: 39px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      background: linear-gradient(135deg, #0b5ed7, #13b7c3);
    }

    .bottom-title {
      font-size: 21px;
      font-weight: 900;
      color: #0b3298;
      margin-bottom: 8px;
    }

    .bottom-desc {
      font-size: 15px;
      line-height: 1.45;
      color: #0a2354;
    }

    .data-list {
      font-size: 17px;
      color: #08275c;
      line-height: 1.5;
    }

    .data-list b {
      color: #0b3298;
      float: right;
      padding-left: 40px;
    }

    .insights-title {
      color: white;
      font-size: 22px;
      font-weight: 900;
      margin-bottom: 11px;
      text-transform: uppercase;
    }

    .insight-line {
      display: grid;
      grid-template-columns: 34px 1fr;
      align-items: center;
      gap: 12px;
      font-size: 15.2px;
      line-height: 1.32;
      margin-bottom: 10px;
      border-bottom: 1px dashed rgba(255,255,255,0.35);
      padding-bottom: 8px;
    }

    .insight-line:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .small-badge {
      width: 31px;
      height: 31px;
      border-radius: 50%;
      background: rgba(255,255,255,0.95);
      color: #0b5ed7;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 900;
    }
  </style>
</head>

<body>
<%
  const data = Array.isArray(items) && items.length ? items : [];

  const total = Number(totalRequerimientos || data.reduce((acc, d) => acc + (Number(d.cantidad) || 0), 0));
  const totalTop = data.reduce((acc, d) => acc + (Number(d.cantidad) || 0), 0);
  const maxVal = Math.max(...data.map(d => Number(d.cantidad) || 0), 1);

  const top1 = data[0] || { nombre: '-', cantidad: 0, porcentaje: '0.00%' };
  const top3 = data.slice(0, 3).reduce((acc, d) => acc + (Number(d.cantidad) || 0), 0);
  const pctTop3 = total ? ((top3 / total) * 100).toFixed(2) + '%' : '0.00%';
  const pctTop10 = total ? ((totalTop / total) * 100).toFixed(2) + '%' : '0.00%';

  const insightsFinal = Array.isArray(insights) && insights.length
    ? insights
    : [
      insight || 'Los principales requerimientos concentran oportunidades de mejora para priorizar recursos operativos.',
      'La gestión del top 10 permite enfocar acciones sobre las demandas más recurrentes.',
      'El seguimiento mensual facilita controlar recurrencias y fortalecer la planificación del servicio.'
    ];

  function pct(cantidad) {
    const value = Number(cantidad) || 0;
    return total ? ((value / total) * 100).toFixed(2) + '%' : '0.00%';
  }

  function cortar(texto, largo) {
    const t = String(texto || '');
    return t.length > largo ? t.substring(0, largo - 3) + '...' : t;
  }
%>

<div class="canvas">
  <div class="corner-ribbon"></div>

  <div class="slide-title-row">
    <div class="title-left">
      <div class="title-accent"></div>
      <h1 class="main-title"><%= titulo || 'TOP 10 REQUERIMIENTOS - PERIODO' %></h1>
    </div>

    <div class="logo-area">
      <div class="logo-dot"></div>
      <div><%= logoText || 'COMM' %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi">
      <div class="kpi-icon blue">▣</div>
      <div>
        <div class="kpi-label">TOTAL REQUERIMIENTOS</div>
        <div class="kpi-value value-blue"><%= total %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon teal">#</div>
      <div>
        <div class="kpi-label">CATEGORÍAS TOP</div>
        <div class="kpi-value value-teal"><%= data.length %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon orange">★</div>
      <div>
        <div class="kpi-label">PRINCIPAL REQUERIMIENTO</div>
        <div class="kpi-small-value"><%= cortar(top1.nombre, 32) %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon purple">●</div>
      <div>
        <div class="kpi-label">CANTIDAD PRINCIPAL</div>
        <div class="kpi-value value-purple"><%= top1.cantidad %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon blue">%</div>
      <div>
        <div class="kpi-label">PARTICIPACIÓN TOP 3</div>
        <div class="kpi-value value-blue"><%= pctTop3 %></div>
      </div>
    </div>

    <div class="kpi">
      <div class="kpi-icon teal">▦</div>
      <div>
        <div class="kpi-label">COBERTURA TOP 10</div>
        <div class="kpi-value value-teal"><%= pctTop10 %></div>
      </div>
    </div>
  </div>

  <div class="main-content">
    <div class="panel">
      <div class="panel-title">GRÁFICO TOP 10 REQUERIMIENTOS</div>

      <div class="chart-area">
        <% data.slice(0, 10).forEach((item, idx) => {
          const cantidad = Number(item.cantidad) || 0;
          const width = maxVal ? Math.max(4, (cantidad / maxVal) * 100) : 0;
        %>
          <div class="bar-row">
            <div class="rank"><%= idx + 1 %></div>
            <div class="name"><%= item.nombre %></div>
            <div class="bar-track">
              <div class="bar-fill" style="width:<%= width %>%"></div>
            </div>
            <div class="qty"><%= cantidad %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">TABLA TOP 10 REQUERIMIENTOS</div>

      <div class="table-area">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Requerimiento</th>
              <th>Cant.</th>
              <th>%</th>
            </tr>
          </thead>

          <tbody>
            <% data.slice(0, 10).forEach((item, idx) => { %>
              <tr>
                <td class="td-rank"><%= idx + 1 %></td>
                <td class="td-name"><%= item.nombre %></td>
                <td class="td-num"><%= item.cantidad %></td>
                <td class="td-pct"><%= item.porcentaje || pct(item.cantidad) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="bottom-row">
    <div class="bottom-card">
      <div class="big-icon">↗</div>
      <div>
        <div class="bottom-title">Concentración de Requerimientos</div>
        <div class="bottom-desc">
          El análisis del Top 10 permite identificar las solicitudes más recurrentes y priorizar acciones de mejora operativa.
        </div>
      </div>
    </div>

    <div class="bottom-card teal-border">
      <div class="big-icon">▤</div>
      <div style="width:100%;">
        <div class="bottom-title">Datos del Top 10</div>
        <div class="data-list">
          TOTAL: <b><%= total %></b><br>
          TOP 10: <b><%= totalTop %></b><br>
          COBERTURA: <b><%= pctTop10 %></b>
        </div>
      </div>
    </div>

    <div class="bottom-card dark">
      <div class="insights-title">INSIGHTS EJECUTIVOS</div>

      <% insightsFinal.slice(0,3).forEach((txt, idx) => { %>
        <div class="insight-line">
          <div class="small-badge"><%= idx === 0 ? '●' : idx === 1 ? '✓' : '⌕' %></div>
          <div><%= txt %></div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
</body>
</html>
